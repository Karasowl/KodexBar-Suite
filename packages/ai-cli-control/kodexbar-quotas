def codex_auth_path(home: Path | None = None) -> Path:
    root = home or home_directory()
    codex_home = os.environ.get("CODEX_HOME")
    if codex_home:
        return Path(codex_home).expanduser() / "auth.json"
    return root / ".codex" / "auth.json"


def codex_access_credentials(home: Path | None = None) -> tuple[str, str | None]:
    """Return (access_token, account_id). Never returns secrets in exceptions."""
    path = codex_auth_path(home)
    try:
        payload = read_json(path)
    except FileNotFoundError:
        raise FetchFallback(CODEX_AUTH_NOT_FOUND, "authentication")
    except PermissionError:
        # Local permissions / infrastructure: not an auth re-login signal.
        raise FetchFallback(CODEX_AUTH_UNREADABLE, "permanent", False)
    except OSError:
        raise FetchFallback(CODEX_AUTH_UNREADABLE, "permanent", False)
    except json.JSONDecodeError:
        # Corrupt file is permanent/parse, not authentication.
        raise FetchFallback(CODEX_AUTH_INVALID_JSON, "permanent", False)
    if not isinstance(payload, dict):
        raise FetchFallback(CODEX_AUTH_MISSING_TOKENS, "authentication")

    api_key = payload.get("OPENAI_API_KEY")
    if isinstance(api_key, str) and api_key.strip():
        return require_header_safe_credential(api_key, CODEX_CREDENTIAL_MALFORMED), None

    tokens = payload.get("tokens")
    if not isinstance(tokens, dict):
        raise FetchFallback(CODEX_AUTH_MISSING_TOKENS, "authentication")

    access = tokens.get("access_token")
    if not isinstance(access, str) or not access.strip():
        access = tokens.get("accessToken")
    if not isinstance(access, str) or not access.strip():
        raise FetchFallback(CODEX_AUTH_MISSING_TOKENS, "authentication")

    account_id = tokens.get("account_id")
    if not isinstance(account_id, str) or not account_id.strip():
        account_id = tokens.get("accountId")
    account = account_id.strip() if isinstance(account_id, str) and account_id.strip() else None
    if account is not None and credential_has_control_chars(account):
        raise FetchFallback(CODEX_CREDENTIAL_MALFORMED, "authentication", False)
    return require_header_safe_credential(access, CODEX_CREDENTIAL_MALFORMED), account


def _parse_toml_quoted_string(rest: str) -> tuple[str | None, bool]:
    """Parse a TOML basic or literal string at the start of rest.

    Returns (value, ok). ok is False when the line is ambiguous or malformed.
    """
    if not rest:
        return None, False
    quote = rest[0]
    if quote not in ('"', "'"):
        # Bare value: stop at inline comment or end of line.
        bare = rest.split("#", 1)[0].strip()
        if not bare:
            return None, False
        return bare, True
    if quote == "'":
        end = rest.find("'", 1)
        if end < 0:
            return None, False
        value = rest[1:end]
        tail = rest[end + 1 :].strip()
        if tail and not tail.startswith("#"):
            return None, False
        return value, True
    # Double-quoted basic string with simple escapes.
    out: list[str] = []
    index = 1
    while index < len(rest):
        ch = rest[index]
        if ch == '"':
            tail = rest[index + 1 :].strip()
            if tail and not tail.startswith("#"):
                return None, False
            return "".join(out), True
        if ch == "\\" and index + 1 < len(rest):
            nxt = rest[index + 1]
            escapes = {"n": "\n", "t": "\t", "r": "\r", '"': '"', "\\": "\\"}
            if nxt not in escapes:
                return None, False
            out.append(escapes[nxt])
            index += 2
            continue
        out.append(ch)
        index += 1
    return None, False


def parse_chatgpt_base_url_text(text: str) -> str | None:
    """Extract chatgpt_base_url from TOML text without falling back to a default host.

    Uses tomllib when available. On parse failure raises FetchFallback (fail closed).
    Without tomllib, a minimal line parser respects quotes and inline comments.
    """
    if tomllib is not None:
        try:
            data = tomllib.loads(text)
        except Exception:
            raise FetchFallback(CODEX_CONFIG_TOML_INVALID, "permanent", False)
        if not isinstance(data, dict):
            return None
        value = data.get("chatgpt_base_url")
        if isinstance(value, str) and value.strip():
            return value.strip().rstrip("/")
        return None

    found: str | None = None
    for raw_line in text.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        match = re.match(r"^chatgpt_base_url\s*=\s*(.+)$", line)
        if not match:
            continue
        value, ok = _parse_toml_quoted_string(match.group(1).strip())
        if not ok or value is None or not value.strip():
            raise FetchFallback(CODEX_CONFIG_TOML_INVALID, "permanent", False)
        found = value.strip().rstrip("/")
    return found


def read_chatgpt_base_url(home: Path | None = None) -> str | None:
    """Read chatgpt_base_url from ~/.codex/config.toml (stdlib). Fail closed on bad TOML."""
    root = home or home_directory()
    config_path = root / ".codex" / "config.toml"
    if not config_path.is_file():
        return None
    try:
        text = config_path.read_text(encoding="utf-8")
    except OSError:
        return None
    return parse_chatgpt_base_url_text(text)


def codex_usage_url(home: Path | None = None) -> str:
    base = read_chatgpt_base_url(home)
    if base and "/backend-api" not in base:
        return f"{base}{CODEX_USAGE_PATH_ALT}"
    if base:
        return f"{base}{CODEX_USAGE_PATH_WHAM}"
    return f"{CODEX_DEFAULT_BASE}{CODEX_USAGE_PATH_WHAM}"


def _codex_finite_number(value: Any) -> float | None:
    """Return a finite float, or None when the value is not a real number."""
    if isinstance(value, bool) or not isinstance(value, (int, float)):
        return None
    try:
        number = float(value)
    except (OverflowError, ValueError, TypeError):
        # Giant JSON integers (hundreds of digits) overflow float() — treat as unusable.
        return None
    if not math.isfinite(number):
        return None
    return number


def _percent_in_range(value: float) -> bool:
    """True when value is a usable utilization percent in [0, 100]."""
    return 0.0 <= value <= 100.0


def map_codex_window(value: Any) -> dict[str, Any] | None:
    """Map one Codex rate-limit window. Raises FetchFallback on corrupt numerics."""
    if not isinstance(value, dict):
        return None
    used = value.get("used_percent")
    if used is None:
        used = value.get("usedPercent")
    used_number = _codex_finite_number(used)
    if used is not None and isinstance(used, (int, float)) and not isinstance(used, bool):
        # Present but non-finite (NaN/Infinity) or outside [0, 100]: schema drift / corrupt.
        if used_number is None or not _percent_in_range(used_number):
            raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True)
    if used_number is None:
        return None
    window: dict[str, Any] = {"usedPercent": used_number}
    reset_at = value.get("reset_at")
    if reset_at is None:
        reset_at = value.get("resetsAt")
    if isinstance(reset_at, (int, float)) and not isinstance(reset_at, bool):
        reset_number = _codex_finite_number(reset_at)
        if reset_number is None or not (CODEX_TS_MIN <= reset_number <= CODEX_TS_MAX):
            raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True)
        window["resetsAt"] = unix_seconds_to_iso(reset_number)
    elif isinstance(reset_at, str) and reset_at:
        window["resetsAt"] = reset_at
    limit_seconds = value.get("limit_window_seconds")
    if isinstance(limit_seconds, (int, float)) and not isinstance(limit_seconds, bool):
        limit_number = _codex_finite_number(limit_seconds)
        if limit_number is None or limit_number < 0 or limit_number > CODEX_WINDOW_SECONDS_MAX:
            raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True)
        window["windowMinutes"] = int(limit_number) // 60
    else:
        minutes = value.get("windowMinutes")
        if isinstance(minutes, (int, float)) and not isinstance(minutes, bool):
            minutes_number = _codex_finite_number(minutes)
            if minutes_number is None or minutes_number < 0 or minutes_number > (CODEX_WINDOW_SECONDS_MAX // 60):
                raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True)
            window["windowMinutes"] = int(minutes_number)
    return window


def normalize_codex_primary_secondary(
    primary: dict[str, Any] | None,
    secondary: dict[str, Any] | None,
) -> tuple[dict[str, Any] | None, dict[str, Any] | None]:
    """Assign session (300) to primary and weekly (10080) to secondary. Other durations stay unknown."""
    candidates = [w for w in (primary, secondary) if isinstance(w, dict)]
    session = next((w for w in candidates if w.get("windowMinutes") == 300), None)
    weekly = next((w for w in candidates if w.get("windowMinutes") == 10080), None)
    if session is not None or weekly is not None:
        return session, weekly
    # Unknown durations: keep API order but only when minutes match the widget normalizer set.
    return primary, secondary


def map_codex_additional_limits(items: Any) -> list[dict[str, Any]]:
    if not isinstance(items, list):
        return []
    extras: list[dict[str, Any]] = []
    for item in items:
        if not isinstance(item, dict):
            continue
        limit_id = item.get("limit_id") or item.get("limitId") or item.get("id")
        metered = item.get("metered_feature") or item.get("meteredFeature") or item.get("limit_name") or item.get("limitName")
        if isinstance(limit_id, str) and limit_id in ("codex-spark", "codex-spark-weekly"):
            window_id = limit_id
            title = "Codex Spark" if limit_id == "codex-spark" else "Codex Spark Weekly"
        else:
            slug_source = limit_id if isinstance(limit_id, str) and limit_id else metered
            if not isinstance(slug_source, str) or not slug_source:
                continue
            slug = re.sub(r"[^a-z0-9]+", "-", slug_source.lower()).strip("-")
            window_id = slug if slug.startswith("codex-") else f"codex-{slug}"
            title = str(metered or limit_id or window_id)
        raw_window = item.get("rate_limit") or item.get("window") or item
        if isinstance(raw_window, dict) and "primary_window" in raw_window:
            mapped = map_codex_window(raw_window.get("primary_window"))
        else:
            mapped = map_codex_window(raw_window)
        if mapped is None:
            continue
        extras.append({"id": window_id, "title": title, "window": mapped})
    return extras


def map_codex_reset_credits(raw: Any) -> dict[str, Any] | None:
    """Map rate_limit_reset_credits. Only when available_count > 0."""
    if not isinstance(raw, dict):
        return None
    count_raw = raw.get("available_count")
    if count_raw is None:
        count_raw = raw.get("applicable_available_count")
    count_n = _coerce_finite_number(count_raw)
    if count_n is None or count_n <= 0:
        return None
    credits_out: list[dict[str, str]] = []
    for key in ("credits", "reset_credits", "items"):
        items = raw.get(key)
        if not isinstance(items, list):
            continue
        for item in items:
            if not isinstance(item, dict):
                continue
            expires = item.get("expires_at") or item.get("expiresAt")
            if isinstance(expires, str) and expires:
                credits_out.append({"expires_at": expires})
        break
    return {"availableCount": int(count_n), "credits": credits_out}


def map_codex_credits(raw: Any) -> dict[str, Any] | None:
    """Top-level credits only when balance is a number > 0 (string balances coerced)."""
    if not isinstance(raw, dict):
        return None
    balance = _coerce_finite_number(raw.get("balance"))
    if balance is None or balance <= 0:
        return None
    return {"remaining": balance}


def map_codex_usage(payload: Any, updated_at: str | None = None) -> dict[str, Any]:
    """Map CodexUsageResponse (wham/usage) to the widget envelope.

    Any unexpected mapping failure becomes invalid_response so the native path
    can fall back to the companion instead of crashing the process.
    """
    try:
        if not isinstance(payload, dict):
            raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True)

        rate_limit = payload.get("rate_limit") if isinstance(payload.get("rate_limit"), dict) else {}
        primary_raw = map_codex_window(rate_limit.get("primary_window"))
        secondary_raw = map_codex_window(rate_limit.get("secondary_window"))
        primary, secondary = normalize_codex_primary_secondary(primary_raw, secondary_raw)
        extras = map_codex_additional_limits(payload.get("additional_rate_limits"))

        if primary is None and secondary is None and not extras:
            raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True)

        plan_type = payload.get("plan_type")
        identity: dict[str, Any] = {"providerID": "codex"}
        if isinstance(plan_type, str) and plan_type:
            identity["loginMethod"] = plan_type

        usage: dict[str, Any] = {
            "identity": identity,
            "primary": primary,
            "secondary": secondary,
            "tertiary": None,
            "updatedAt": updated_at or iso_now(),
        }
        if extras:
            usage["extraRateWindows"] = extras
        reset_credits = map_codex_reset_credits(payload.get("rate_limit_reset_credits"))
        if reset_credits is not None:
            usage["codexResetCredits"] = reset_credits

        entry: dict[str, Any] = {
            "provider": "codex",
            "source": "oauth",
            "usage": usage,
            "engine": "kodexbar",
        }
        credits = map_codex_credits(payload.get("credits"))
        if credits is not None:
            entry["credits"] = credits
        return entry
    except FetchFallback:
        raise
    except Exception:
        raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True)


def fetch_codex(home: Path | None = None) -> dict[str, Any]:
    """Native Codex OAuth usage. Auth errors return provider entries (no refresh)."""
    try:
        token, account_id = codex_access_credentials(home)
    except FetchFallback as error:
        if error.category == "authentication":
            return provider_error("codex", "oauth", str(error), "authentication", False)
        raise

    headers = {
        "Authorization": f"Bearer {token}",
        "User-Agent": "CodexBar",
        "Accept": "application/json",
    }
    if account_id:
        headers["ChatGPT-Account-Id"] = account_id

    url = codex_usage_url(home)
    try:
        status, _resp_headers, body = http_request(
            "GET", url, headers, None, CODEX_TIMEOUT_SECONDS
        )
    except FetchFallback as error:
        raise FetchFallback(
            human_native_error_message("codex", error.category),
            error.category,
            error.retryable,
        ) from error

    if status in (401, 403):
        return provider_error("codex", "oauth", CODEX_AUTH_EXPIRED, "authentication", False)
    if status != 200:
        retryable = status in (408, 425) or status >= 500
        if retryable:
            category = "timeout" if status == 408 else "network"
            raise FetchFallback(human_native_error_message("codex", category), category, True)
        raise FetchFallback(CODEX_PERMANENT, "permanent", False)

    try:
        payload = json.loads(body.decode("utf-8"))
    except (UnicodeDecodeError, json.JSONDecodeError) as error:
        raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True) from error
    try:
        return map_codex_usage(payload)
    except FetchFallback:
        raise
    except Exception:
        raise FetchFallback(CODEX_INVALID_RESPONSE, "invalid_response", True)


# --- Grok native (cookie-free gRPC-web billing) ---
#
# WARNING: The protobuf scan below is heuristic and fragile. There is no public
# schema for GetGrokCreditsConfig. Field paths and wire layout may change.


def grok_auth_path(home: Path | None = None) -> Path:
    root = home or home_directory()
    grok_home = os.environ.get("GROK_HOME")
    if grok_home:
        return Path(grok_home).expanduser() / "auth.json"
    return root / ".grok" / "auth.json"


def _grok_scope_preference(scope: str) -> tuple[int, str]:
    if scope.startswith("https://auth.x.ai::"):
        return (0, scope)
    if scope == "https://accounts.x.ai/sign-in" or "/sign-in" in scope:
        return (1, scope)
    return (2, scope)


def _parse_iso_expiry(value: Any) -> datetime | None:
    if not isinstance(value, str) or not value.strip():
        return None
    text = value.strip().replace("Z", "+00:00")
    try:
        parsed = datetime.fromisoformat(text)
    except ValueError:
        return None
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=timezone.utc)
    return parsed


def grok_access_credentials(home: Path | None = None) -> tuple[str, dict[str, Any]]:
    """Return (bearer key, selected auth entry). No refresh of OAuth tokens."""
    path = grok_auth_path(home)
    try:
        payload = read_json(path)
    except FileNotFoundError:
        raise FetchFallback(GROK_AUTH_NOT_FOUND, "authentication")
    except PermissionError:
        raise FetchFallback(GROK_AUTH_UNREADABLE, "permanent", False)
    except OSError:
        raise FetchFallback(GROK_AUTH_UNREADABLE, "permanent", False)
    except json.JSONDecodeError:
        raise FetchFallback(GROK_AUTH_INVALID_JSON, "permanent", False)
    if not isinstance(payload, dict) or not payload:
        raise FetchFallback(GROK_AUTH_MISSING_KEY, "authentication")

    candidates: list[tuple[tuple[int, str], dict[str, Any]]] = []
    for scope, entry in payload.items():
        if not isinstance(scope, str) or not isinstance(entry, dict):
            continue
        candidates.append((_grok_scope_preference(scope), entry))
    if not candidates:
        raise FetchFallback(GROK_AUTH_MISSING_KEY, "authentication")
    candidates.sort(key=lambda item: item[0])
    entry = candidates[0][1]

    key = entry.get("key")
    if not isinstance(key, str) or not key.strip():
        raise FetchFallback(GROK_AUTH_MISSING_KEY, "authentication")

    expires = _parse_iso_expiry(entry.get("expires_at") or entry.get("expiresAt"))
    if expires is not None and expires <= datetime.now(timezone.utc):
        raise FetchFallback(GROK_AUTH_RELOGIN, "authentication")

    return require_header_safe_credential(key, GROK_CREDENTIAL_MALFORMED), entry


def _read_protobuf_varint(view: memoryview, index: int) -> tuple[int, int]:
    result = 0
    shift = 0
    length = len(view)
    while index < length:
        byte = view[index]
        index += 1
        result |= (byte & 0x7F) << shift
        if (byte & 0x80) == 0:
            return result, index
        shift += 7
        if shift > 63:
            raise ValueError("varint too long")
    raise ValueError("truncated varint")


class _ProtobufScanState:
    __slots__ = ("valid", "field_count", "percents", "timestamps", "surfaces")

    def __init__(self) -> None:
        self.valid = True
        self.field_count = 0
        self.percents: list[tuple[tuple[int, ...], float]] = []
        self.timestamps: list[tuple[tuple[int, ...], int]] = []
        # Surface breakdown entries: (surface_id, used_percent) from dossier field 7.
        self.surfaces: list[tuple[int, float]] = []


def _parse_grok_surface_submessage(view: memoryview) -> tuple[int | None, float | None]:
    """Parse one repeated field-7 surface entry: id (field 1 varint) + percent (field 2 fixed32)."""
    surface_id: int | None = None
    percent: float | None = None
    index = 0
    length = len(view)
    while index < length:
        try:
            tag, index = _read_protobuf_varint(view, index)
        except ValueError:
            return surface_id, percent
        field_number = tag >> 3
        wire_type = tag & 0x07
        if field_number == 0:
            return surface_id, percent
        if wire_type == 0:
            try:
                value, index = _read_protobuf_varint(view, index)
            except ValueError:
                return surface_id, percent
            if field_number == 1:
                surface_id = int(value)
        elif wire_type == 1:
            if index + 8 > length:
                return surface_id, percent
            index += 8
        elif wire_type == 2:
            try:
                size, index = _read_protobuf_varint(view, index)
            except ValueError:
                return surface_id, percent
            if size < 0 or index + size > length:
                return surface_id, percent
            index += size
        elif wire_type == 5:
            if index + 4 > length:
                return surface_id, percent
            value = struct.unpack_from("<f", view, index)[0]
            index += 4
            # Capture field 2 as-is (including NaN/Inf/out-of-range). Filtering
            # invalid percents here would drop the bad entry and let a partial
            # surface set look like a complete weekly composition downstream.
            if field_number == 2:
                percent = float(value)
        else:
            return surface_id, percent
    return surface_id, percent


def _scan_protobuf_fields(
    view: memoryview,
    path: tuple[int, ...],
    depth: int,
    state: _ProtobufScanState,
) -> None:
    """Walk protobuf wire fields with depth/field caps. Uses memoryview (no submessage copies)."""
    if not state.valid:
        return
    if depth > PROTOBUF_MAX_DEPTH:
        state.valid = False
        return
    index = 0
    length = len(view)
    while index < length:
        if state.field_count >= PROTOBUF_MAX_FIELDS:
            state.valid = False
            return
        try:
            tag, index = _read_protobuf_varint(view, index)
        except ValueError:
            state.valid = False
            return
        field_number = tag >> 3
        wire_type = tag & 0x07
        if field_number == 0:
            state.valid = False
            return
        state.field_count += 1
        field_path = path + (field_number,)
        if wire_type == 0:
            try:
                value, index = _read_protobuf_varint(view, index)
            except ValueError:
                state.valid = False
                return
            if GROK_TS_MIN <= value <= GROK_TS_MAX:
                state.timestamps.append((field_path, value))
        elif wire_type == 1:
            if index + 8 > length:
                state.valid = False
                return
            index += 8
        elif wire_type == 2:
            try:
                size, index = _read_protobuf_varint(view, index)
            except ValueError:
                state.valid = False
                return
            if size < 0 or index + size > length:
                state.valid = False
                return
            nested = view[index : index + size]
            index += size
            # Length-delimited may be a submessage, string, or bytes. Try as submessage.
            # Opaque non-message payloads must not invalidate the parent walk.
            if size > 0:
                # Dossier: repeated field 7 under root field 1 holds surface id + percent.
                if field_path == (1, 7):
                    surface_id, surface_percent = _parse_grok_surface_submessage(nested)
                    if surface_id is not None and surface_percent is not None:
                        state.surfaces.append((surface_id, surface_percent))
                nested_state = _ProtobufScanState()
                nested_state.field_count = state.field_count
                _scan_protobuf_fields(nested, field_path, depth + 1, nested_state)
                state.field_count = nested_state.field_count
                if nested_state.valid:
                    state.percents.extend(nested_state.percents)
                    state.timestamps.extend(nested_state.timestamps)
                    state.surfaces.extend(nested_state.surfaces)
                if state.field_count >= PROTOBUF_MAX_FIELDS:
                    state.valid = False
                    return
        elif wire_type == 5:
            if index + 4 > length:
                state.valid = False
                return
            value = struct.unpack_from("<f", view, index)[0]
            index += 4
            if 0.0 <= value <= 100.0:
                state.percents.append((field_path, value))
        else:
            state.valid = False
            return


def sanitize_grpc_message(value: str) -> str:
    """ASCII-printable truncation for grpc-message (never echo raw secrets or binary)."""
    cleaned = "".join(ch if 32 <= ord(ch) < 127 else " " for ch in value)
    return cleaned[:200].strip()


def parse_grpc_web_trailers(payload: bytes) -> tuple[int | None, str | None]:
    """Parse gRPC-web trailer block (HTTP/1 header lines) for grpc-status / grpc-message."""
    text = payload.decode("utf-8", errors="replace")
    status: int | None = None
    message: str | None = None
    for raw_line in text.replace("\r\n", "\n").split("\n"):
        line = raw_line.strip()
        if not line or ":" not in line:
            continue
        key, _, value = line.partition(":")
        key_l = key.strip().lower()
        value = value.strip()
        if key_l == "grpc-status":
            try:
                status = int(value)
            except ValueError:
                status = None
        elif key_l == "grpc-message":
            message = sanitize_grpc_message(value)
    return status, message


def parse_grpc_web_frames(body: bytes) -> tuple[bytes | None, int | None, str | None]:
    """Decode the full gRPC-web frame sequence.

    Flag bit 0x80 marks trailer frames. Returns (data_payload_or_None, grpc_status, grpc_message).
    A non-zero trailer status wins over any data frames (response is not success).
    """
    if len(body) < 5:
        raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)
    data_parts: list[bytes] = []
    grpc_status: int | None = None
    grpc_message: str | None = None
    offset = 0
    while offset < len(body):
        if offset + 5 > len(body):
            raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)
        flags = body[offset]
        message_length = int.from_bytes(body[offset + 1 : offset + 5], "big")
        start = offset + 5
        end = start + message_length
        if end > len(body):
            raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)
        frame_payload = body[start:end]
        offset = end
        if flags & 0x80:
            trailer_status, trailer_message = parse_grpc_web_trailers(frame_payload)
            if trailer_status is not None:
                grpc_status = trailer_status
            if trailer_message is not None:
                grpc_message = trailer_message
        else:
            data_parts.append(frame_payload)
    data = b"".join(data_parts) if data_parts else None
    return data, grpc_status, grpc_message


def unwrap_grpc_web_frame(body: bytes) -> bytes:
    """Compatibility helper: first data frame payload only (prefer parse_grpc_web_frames)."""
    data, _status, _message = parse_grpc_web_frames(body)
    if data is None:
        raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)
    return data


def map_grok_segments(surfaces: list[tuple[int, float]]) -> list[dict[str, Any]]:
    """Build weekly composition segments from (surface_id, percent_points) pairs.

    Surfaces are contributions to the single weekly pool (not independent budgets).
    ``points`` are percentage points that sum (approximately) to secondary usedPercent.

    Order: points descending, then surface_id ascending as a stable tiebreaker.
    Only surfaces with points > 0 are included (zero is a valid component but is
    omitted from the legend). Known titles come from GROK_SURFACE_NAMES; unknown
    ids use a generic label without the raw id.

    This builder skips invalid rows for legend construction only. Callers that
    publish segments must first require every supplied component to be valid via
    ``_grok_surface_components_valid`` so one bad entry never becomes a partial
    composition, then check ``_grok_segments_match_weekly``.
    """
    candidates: list[tuple[float, int, str]] = []
    for surface_id, percent in surfaces:
        if not isinstance(surface_id, int) or isinstance(surface_id, bool):
            continue
        if not isinstance(percent, (int, float)) or isinstance(percent, bool):
            continue
        try:
            points = float(percent)
        except (OverflowError, ValueError, TypeError):
            continue
        if not math.isfinite(points) or not _percent_in_range(points) or points <= 0:
            continue
        title = GROK_SURFACE_NAMES.get(surface_id) or "Other surface"
        candidates.append((points, surface_id, title))
    candidates.sort(key=lambda item: (-item[0], item[1]))
    return [{"title": title, "points": points} for points, _surface_id, title in candidates]


def _grok_surface_components_valid(surfaces: list[tuple[int, float]]) -> bool:
    """True when every supplied surface is a usable weekly composition component.

    Remote Build/API/Imagine values are one composition, not independent quotas.
    A single non-finite or out-of-range percent (or a malformed row) invalidates
    the whole composition: callers must omit segments and keep the solid weekly
    bar. Zero is valid. Do not drop the bad row and accept the remainder.
    """
    for item in surfaces:
        if not isinstance(item, (tuple, list)) or len(item) != 2:
            return False
        surface_id, percent = item[0], item[1]
        if not isinstance(surface_id, int) or isinstance(surface_id, bool):
            return False
        if not isinstance(percent, (int, float)) or isinstance(percent, bool):
            return False
        try:
            points = float(percent)
        except (OverflowError, ValueError, TypeError):
            return False
        if not math.isfinite(points) or not _percent_in_range(points):
            return False
    return True


def _grok_segments_match_weekly(
    segments: list[dict[str, Any]], used_percent: float
) -> bool:
    """True when segment points form a valid composition of the weekly usedPercent.

    Requires every points value finite and in [0, 100], sum(points) strictly not
    greater than 100.0 (no upward slack), and sum matching usedPercent within
    ``GROK_SEGMENTS_FLOAT_ABS_TOL`` via ``math.isclose`` only when the total is
    already in [0, 100]. No product-level slack: a 0.8pp gap is rejected. On
    False, map_grok_usage omits segments.
    """
    if not segments:
        return False
    total = 0.0
    for item in segments:
        if not isinstance(item, dict):
            return False
        raw = item.get("points")
        if not isinstance(raw, (int, float)) or isinstance(raw, bool):
            return False
        try:
            points = float(raw)
        except (OverflowError, ValueError, TypeError):
            return False
        if not math.isfinite(points) or not _percent_in_range(points):
            return False
        total += points
    if not math.isfinite(total):
        return False
    # Strict ceiling: any total > 100.0 is rejected (no float noise slack above 100).
    if total > 100.0:
        return False
    if not math.isclose(
        total, used_percent, rel_tol=0.0, abs_tol=GROK_SEGMENTS_FLOAT_ABS_TOL
    ):
        return False
    return True


def scan_grok_billing_protobuf(
    message: bytes,
) -> tuple[float, str | None, list[tuple[int, float]]]:
    """Heuristic scan with normative path filters and strict validity.

    Percent candidates must end with field 1 (dossier). Prefer the shortest such path.
    Preferred timestamp path is [1, 5, 1]. Surface breakdown lives in repeated field 7.
    Any truncation or invalid wire type invalidates the whole parse even if a percent
    candidate was already seen.

    Does not extract a dollar balance: live captures at balance 0 have no observable
    credits/remaining field on the wire (no fixed64 money, no out-of-percent fixed32
    outside usage windows). Revisit when a balance > 0 account reveals the field.
    """
    state = _ProtobufScanState()
    _scan_protobuf_fields(memoryview(message), (), 0, state)
    if not state.valid:
        raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)

    percent_candidates = [
        (len(field_path), field_path, value)
        for field_path, value in state.percents
        if field_path and field_path[-1] == 1
    ]
    used_percent: float | None = None
    if percent_candidates:
        percent_candidates.sort(key=lambda item: (item[0], item[1]))
        used_percent = percent_candidates[0][2]

    resets_at: str | None = None
    preferred = next(
        (value for field_path, value in state.timestamps if field_path == GROK_PREFERRED_TS_PATH),
        None,
    )
    if preferred is not None:
        resets_at = unix_seconds_to_iso(preferred)
    elif state.timestamps:
        resets_at = unix_seconds_to_iso(state.timestamps[0][1])

    if used_percent is None:
        # Period with future reset but no percent => treat as 0% used.
        if resets_at is not None:
            try:
                reset_dt = datetime.fromisoformat(resets_at.replace("Z", "+00:00"))
            except ValueError:
                reset_dt = None
            if reset_dt is not None and reset_dt > datetime.now(timezone.utc):
                used_percent = 0.0
        if used_percent is None:
            raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)

    return used_percent, resets_at, list(state.surfaces)


def map_grok_usage(
    used_percent: float,
    resets_at: str | None,
    auth_entry: dict[str, Any] | None = None,
    updated_at: str | None = None,
    surfaces: list[tuple[int, float]] | None = None,
    credits_remaining: float | None = None,
) -> dict[str, Any]:
    """Map scanned Grok billing fields to the widget envelope.

    Weekly aggregate is emitted as secondary (Weekly). primary stays null so the popup
    labels the main window as Weekly (badge W). Compact tray must not copy secondary into
    the primary/Session slot.

    Surface breakdown (Build/API/Imagine) is a *composition* of the single weekly pool,
    not independent rate limits. It is attached as secondary.segments with percentage
    points per surface. Grok never emits extraRateWindows.

    ``credits_remaining`` is intentionally dormant: the GetGrokCreditsConfig protobuf does
    not expose an observable dollar-balance field at live balance 0 (deep wire walk found
    only percents, timestamps, surface ids, and flags). Leave unwired until a paid account
    with balance > 0 reveals the field; do not invent a dead extraction path.

    Any unexpected mapping failure becomes invalid_response so the native path
    can fall back to the companion instead of crashing the process.
    """
    try:
        if not isinstance(used_percent, (int, float)) or isinstance(used_percent, bool):
            raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)
        try:
            percent = float(used_percent)
        except (OverflowError, ValueError, TypeError):
            # Giant JSON integers overflow float() — same unusable treatment as Codex.
            raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)
        # Same [0, 100] band as the protobuf percent filter and Codex usedPercent.
        if not math.isfinite(percent) or not _percent_in_range(percent):
            raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)
        # Aggregate is weekly usage (not session). Web path does not compute windowMinutes.
        secondary: dict[str, Any] = {"usedPercent": percent}
        if resets_at:
            secondary["resetsAt"] = resets_at
        # Publish composition only when every remote component is valid and the
        # segments reconstruct the weekly aggregate. One invalid component omits
        # segments entirely (never a silent partial composition). Otherwise keep
        # the simple weekly bar (usedPercent/resetsAt without segments).
        surface_list = list(surfaces or [])
        if surface_list and _grok_surface_components_valid(surface_list):
            segments = map_grok_segments(surface_list)
            if segments and _grok_segments_match_weekly(segments, percent):
                secondary["segments"] = segments
        identity: dict[str, Any] = {"providerID": "grok"}
        if isinstance(auth_entry, dict):
            auth_mode = auth_entry.get("auth_mode")
            if auth_mode == "oidc":
                identity["loginMethod"] = "SuperGrok"
            elif isinstance(auth_mode, str) and auth_mode:
                identity["loginMethod"] = auth_mode
            email = auth_entry.get("email")
            if isinstance(email, str) and email:
                identity["accountEmail"] = email
            team_id = auth_entry.get("team_id")
            if isinstance(team_id, str) and team_id:
                identity["accountOrganization"] = team_id
        usage: dict[str, Any] = {
            "identity": identity,
            "primary": None,
            "secondary": secondary,
            "tertiary": None,
            "updatedAt": updated_at or iso_now(),
        }
        entry: dict[str, Any] = {
            "provider": "grok",
            "source": "grok-web",
            "usage": usage,
            "engine": "kodexbar",
        }
        # Dormant credits gate: only emits when a positive balance is *passed in*.
        # fetch_grok does not pass credits_remaining (protobuf has no known balance field).
        credit_n = _coerce_finite_number(credits_remaining)
        if credit_n is not None and credit_n > 0:
            entry["credits"] = {"remaining": credit_n}
        return entry
    except FetchFallback:
        raise
    except Exception:
        raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)


def _grpc_status_from_headers(headers: dict[str, str]) -> int | None:
    for key, value in headers.items():
        if key.lower() in ("grpc-status", "grpc_status"):
            try:
                return int(value.strip())
            except ValueError:
                return None
    return None


def _grpc_message_suggests_invalid_credentials(message: str | None) -> bool:
    """Strong credential evidence only. Generic gRPC status-7 text is not enough.

    Status 7's stock phrase is "permission denied". That alone does not prove an
    invalid token. Require explicit auth/credential signals before treating 7 as
    authentication (re-login). Without them, 7 stays permanent (identity/plan).
    """
    if not message:
        return False
    lowered = message.lower()
    needles = (
        "unauthenticated",
        "unauth",
        "invalid",
        "credential",
        "token",
        "unauthorized",
        "expired",
        "revoked",
        "sign in",
        "log in",
        "login",
    )
    return any(needle in lowered for needle in needles)


def classify_grok_grpc_status(status: int, message: str | None) -> dict[str, Any]:
    """Map gRPC status to a provider error entry, or raise FetchFallback for transient codes.

    - 16 UNAUTHENTICATED → authentication (no companion fallback)
    - 7 PERMISSION_DENIED → context-dependent (see below). Not unconditional auth.
    - 8 RESOURCE_EXHAUSTED → permanent rate-limit / quota (no companion fallback:
      the companion would hit the same limit)
    - 4 DEADLINE_EXCEEDED → timeout (companion may fall back)
    - 14 UNAVAILABLE / 13 INTERNAL → network (companion may fall back)
    - other non-zero → permanent (no companion fallback)

    Status 7 is context-dependent per the Grok billing dossier: x.ai often returns 7 for
    "account without personal team" style identity/plan denials (permanent, not fixed by
    re-login). Map to authentication only when the grpc-message shows credential evidence
    (invalid/expired token, unauthenticated, etc.). Otherwise permanent identity-only.
    """
    if status == 16:
        return provider_error("grok", "grok-web", GROK_AUTH_RELOGIN, "authentication", False)
    if status == 7:
        # Dossier: 7 is NOT always auth. Credential-shaped message → re-login;
        # otherwise identity/plan denial stays permanent (no companion fallback).
        if _grpc_message_suggests_invalid_credentials(message):
            return provider_error("grok", "grok-web", GROK_AUTH_RELOGIN, "authentication", False)
        return provider_error(
            "grok",
            "grok-web",
            GROK_PERMISSION_DENIED,
            "permanent",
            False,
        )
    if status == 8:
        # RESOURCE_EXHAUSTED: rate limit / quota, permanent for this fetch path.
        # Do not fall back to companion (same upstream limit).
        return provider_error("grok", "grok-web", GROK_PERMANENT, "permanent", False)
    if status == 4:
        raise FetchFallback(GROK_TIMEOUT, "timeout", True)
    if status in (13, 14):
        raise FetchFallback(GROK_NETWORK, "network", True)
    return provider_error("grok", "grok-web", GROK_PERMANENT, "permanent", False)


def fetch_grok(home: Path | None = None) -> dict[str, Any]:
    """Native Grok billing via gRPC-web. No OAuth refresh: expired key => re-login."""
    try:
        key, auth_entry = grok_access_credentials(home)
    except FetchFallback as error:
        if error.category == "authentication":
            return provider_error("grok", "grok-web", str(error), "authentication", False)
        raise

    headers = {
        "Authorization": f"Bearer {key}",
        "Origin": "https://grok.com",
        "Referer": "https://grok.com/?_s=usage",
        "Accept": "*/*",
        "Content-Type": "application/grpc-web+proto",
        "x-grpc-web": "1",
        "x-user-agent": "connect-es/2.1.1",
        "User-Agent": "CodexBar",
    }

    last_error: FetchFallback | None = None
    status = 0
    resp_headers: dict[str, str] = {}
    body = b""
    for attempt in range(2):
        try:
            status, resp_headers, body = http_request(
                "POST",
                GROK_CREDITS_URL,
                headers,
                GROK_EMPTY_FRAME,
                GROK_TIMEOUT_SECONDS,
            )
        except FetchFallback as error:
            last_error = error
            if error.retryable and attempt == 0:
                continue
            # Re-raise without chaining secrets from lower layers.
            raise FetchFallback(
                human_native_error_message("grok", error.category),
                error.category,
                error.retryable,
            )

        if status in (408, 502, 503, 504) and attempt == 0:
            category = "timeout" if status == 408 else "network"
            last_error = FetchFallback(
                human_native_error_message("grok", category),
                category,
                True,
            )
            continue
        break
    else:
        if last_error is not None:
            raise last_error

    if status in (401, 403):
        return provider_error("grok", "grok-web", GROK_AUTH_RELOGIN, "authentication", False)
    if status != 200:
        retryable = status in (408, 425) or status >= 500
        if retryable:
            category = "timeout" if status == 408 else "network"
            raise FetchFallback(human_native_error_message("grok", category), category, True)
        raise FetchFallback(GROK_PERMANENT, "permanent", False)

    header_status = _grpc_status_from_headers(resp_headers)
    try:
        data_message, trailer_status, trailer_message = parse_grpc_web_frames(body)
    except FetchFallback:
        raise
    except Exception:
        raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)

    # Trailer status takes precedence when present. Non-zero status is never success,
    # even if a data frame is also present.
    grpc_status = trailer_status if trailer_status is not None else header_status
    if grpc_status is not None and grpc_status != 0:
        return classify_grok_grpc_status(grpc_status, trailer_message)

    if data_message is None:
        # grpc-status 0 (or absent) without data is empty/soft.
        raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)

    try:
        # No credits_remaining: live GetGrokCreditsConfig at balance 0 exposes no dollar
        # balance field (only used%, resets, surfaces, flags). Do not invent extraction.
        used_percent, resets_at, surfaces = scan_grok_billing_protobuf(data_message)
    except FetchFallback:
        raise
    except Exception:
        raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)
    try:
        return map_grok_usage(used_percent, resets_at, auth_entry, surfaces=surfaces)
    except FetchFallback:
        raise
    except Exception:
        raise FetchFallback(GROK_INVALID_RESPONSE, "invalid_response", True)


def upstream_path() -> str | None:
    candidate = shutil.which("codexbar")
    if candidate and os.path.realpath(candidate) != os.path.realpath(__file__):
        return candidate
    return None


def upstream_entries(provider: str, source: str | None) -> list[Any]:
    executable = upstream_path()
    if executable is None:
        raise FetchFallback("upstream codexbar is not installed")
    command = [executable, "usage", "--format", "json", "--json-only", "--provider", provider]
    if source:
        command.extend(["--source", source])
    try:
        completed = subprocess.run(command, capture_output=True, text=True, timeout=TIMEOUT_SECONDS, check=False)
    except subprocess.TimeoutExpired as error:
        raise FetchFallback(
            f"upstream codexbar timed out after {TIMEOUT_SECONDS} seconds",
            "timeout",
            True,
        ) from error
    except OSError as error:
        raise FetchFallback(f"upstream codexbar could not start: {error}") from error
    try:
        value = json.loads(completed.stdout)
    except json.JSONDecodeError as error:
        if not completed.stdout.strip() and completed.returncode != 0:
            raise FetchFallback(f"upstream codexbar exited with status {completed.returncode}") from error
        detail = "empty output" if not completed.stdout.strip() else f"invalid JSON at column {error.colno}"
        raise FetchFallback(f"upstream codexbar returned {detail}", "invalid_response", True) from error
    return value if isinstance(value, list) else [value]


