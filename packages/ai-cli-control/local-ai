#!/usr/bin/env python3
"""Portable inventory and safe control surface for local AI runtimes.

The program deliberately knows about runtimes, not a particular installer.  It
only examines configured roots and a small set of conventional directories. It
never searches a complete home directory, guesses a process to kill, or emits a
made-up throughput value.
"""

from __future__ import annotations

import argparse
import hashlib
import json
import os
from pathlib import Path
import re
import struct
import subprocess
import sys
import time
from dataclasses import dataclass, field
from typing import Any, Iterable
from urllib.error import HTTPError, URLError
from urllib.parse import urlparse
from urllib.request import Request, urlopen

sys.path.insert(0, str(Path(__file__).resolve().parent))
from local_ai_drivers import builtin_drivers
from local_ai_drivers.descriptors import descriptor_drivers


VERSION = "0.9.4"
DEFAULT_TIMEOUT = 2.5
MAX_RESPONSE_BYTES = 2 * 1024 * 1024
MODEL_SUFFIXES = {".gguf", ".safetensors", ".ckpt", ".pt", ".pth", ".onnx", ".bin"}
VALID_KINDS = ("llm", "vision", "image", "video", "audio", "embedding", "unknown")
VALID_STATES = ("active", "loaded", "loading", "unloading", "installed", "disconnected", "unknown", "error")


class LocalAIError(Exception):
    """A safe, user-visible local runtime error."""


@dataclass
class Runtime:
    id: str
    kind: str
    endpoint: str = ""
    enabled: bool = True
    roots: list[Path] = field(default_factory=list)
    service: str = ""


def config_path(value: str | None = None) -> Path:
    if value:
        return Path(value).expanduser()
    configured = os.environ.get("KODEXBAR_LOCAL_AI_CONFIG")
    if configured:
        return Path(configured).expanduser()
    xdg = Path(os.environ.get("XDG_CONFIG_HOME", "~/.config")).expanduser()
    return xdg / "kodexbar" / "local-models.json"


def default_config() -> dict[str, Any]:
    home = Path.home()
    # These are conventional locations only. They are not written to disk and
    # can be replaced entirely by the user's config roots.
    return {
        "refreshSeconds": 15,
        "scanDepth": 3,
        "observeGpuProcesses": True,
        "adapterDescriptors": [],
        "roots": [],
        "knownRoots": [
            str(home / ".ollama" / "models"),
            str(home / ".cache" / "lm-studio" / "models"),
            str(home / ".cache" / "huggingface" / "hub"),
            str(home / "ComfyUI" / "models"),
        ],
        "runtimes": {
            "llama_cpp": {"enabled": True, "endpoint": "http://127.0.0.1:18100", "modelsMax": 1, "sleepIdleSeconds": 120},
            "ollama": {"enabled": True, "endpoint": "http://127.0.0.1:11434"},
            "lm_studio": {"enabled": True, "endpoint": "http://127.0.0.1:1234"},
            "comfyui": {"enabled": True, "endpoint": "http://127.0.0.1:8188"},
            "vllm": {"enabled": True, "endpoint": "http://127.0.0.1:8000"},
        },
    }


def load_config(path: Path) -> dict[str, Any]:
    config = default_config()
    if not path.exists():
        return config
    try:
        raw = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as error:
        raise LocalAIError(f"invalid configuration: {error}") from error
    if not isinstance(raw, dict):
        raise LocalAIError("invalid configuration: root must be an object")
    for key in ("refreshSeconds", "scanDepth", "roots", "knownRoots", "observeGpuProcesses", "adapterDescriptors"):
        if key in raw:
            config[key] = raw[key]
    if isinstance(raw.get("runtimes"), dict):
        for runtime_id, value in raw["runtimes"].items():
            if not isinstance(value, dict):
                continue
            current = config["runtimes"].get(runtime_id, {})
            config["runtimes"][runtime_id] = {**current, **value}
    return config


def normalized_url(value: str) -> str:
    return value.rstrip("/")


def runtime_list(config: dict[str, Any]) -> list[Runtime]:
    result: list[Runtime] = []
    for runtime_id, details in config.get("runtimes", {}).items():
        if not isinstance(details, dict):
            continue
        roots = [Path(item).expanduser() for item in details.get("roots", []) if isinstance(item, str)]
        result.append(Runtime(runtime_id, runtime_id, normalized_url(str(details.get("endpoint", ""))),
                              details.get("enabled", True) is not False, roots, str(details.get("service", ""))))
    return result


def request_json(url: str, method: str = "GET", payload: Any = None, timeout: float = DEFAULT_TIMEOUT) -> Any:
    parsed = urlparse(url)
    if parsed.scheme not in {"http", "https"} or not parsed.netloc:
        raise LocalAIError("runtime endpoint must use http or https")
    body = None if payload is None else json.dumps(payload).encode("utf-8")
    request = Request(url, data=body, method=method, headers={"Accept": "application/json", "Content-Type": "application/json"})
    try:
        with urlopen(request, timeout=timeout) as response:  # nosec B310, endpoint is user-configured localhost by default
            text = response.read(MAX_RESPONSE_BYTES + 1)
            if len(text) > MAX_RESPONSE_BYTES:
                raise LocalAIError("runtime response exceeds the safe size limit")
            text = text.decode("utf-8")
    except HTTPError as error:
        detail = error.read().decode("utf-8", errors="replace")[:240]
        raise LocalAIError(f"HTTP {error.code}: {detail or error.reason}") from error
    except (URLError, OSError) as error:
        raise LocalAIError(str(error.reason if isinstance(error, URLError) else error)) from error
    try:
        return json.loads(text) if text else {}
    except json.JSONDecodeError as error:
        raise LocalAIError("runtime returned invalid JSON") from error


def safe_name(value: Any) -> str:
    return str(value or "").strip()


def model_id(runtime: str, name: str, location: str = "") -> str:
    digest = hashlib.sha256((runtime + "\0" + name + "\0" + location).encode("utf-8")).hexdigest()[:12]
    return f"{runtime}:{digest}"


def metadata_strings(path: Path) -> tuple[dict[str, str], str]:
    """Read only small self-describing headers, never tensor payloads."""
    try:
        with path.open("rb") as handle:
            lead = handle.read(1024 * 1024 + 16)
    except PermissionError:
        return {}, "permission denied"
    except OSError:
        return {}, "unreadable"
    if path.suffix.lower() == ".safetensors" and len(lead) >= 8:
        length = struct.unpack_from("<Q", lead)[0]
        if length > 1024 * 1024 or 8 + length > len(lead):
            return {}, ""
        try:
            header = json.loads(lead[8:8 + length].decode("utf-8"))
            raw = header.get("__metadata__", {}) if isinstance(header, dict) else {}
            return {str(key): str(value) for key, value in raw.items()}, ""
        except (UnicodeDecodeError, json.JSONDecodeError):
            return {}, ""
    if path.suffix.lower() != ".gguf" or len(lead) < 24 or lead[:4] != b"GGUF":
        return {}, ""
    try:
        count = struct.unpack_from("<Q", lead, 16)[0]
        cursor, values = 24, {}
        for _ in range(min(count, 128)):
            length = struct.unpack_from("<Q", lead, cursor)[0]
            cursor += 8
            key = lead[cursor:cursor + length].decode("utf-8")
            cursor += length
            value_type = struct.unpack_from("<I", lead, cursor)[0]
            cursor += 4
            if value_type == 8:
                text_length = struct.unpack_from("<Q", lead, cursor)[0]
                cursor += 8
                values[key] = lead[cursor:cursor + text_length].decode("utf-8")
                cursor += text_length
            elif value_type in (0, 1, 7): cursor += 1
            elif value_type in (2, 3): cursor += 2
            elif value_type in (4, 5, 6): cursor += 4
            elif value_type in (10, 11, 12): cursor += 8
            else: break
            if cursor > len(lead): break
        return values, ""
    except (IndexError, struct.error, UnicodeDecodeError):
        return {}, ""


def classify(name: str, declared: str = "", metadata: dict[str, str] | None = None, location: str = "") -> tuple[str, str]:
    value = (declared or "").lower()
    aliases = {
        "llm": "llm", "text-generation": "llm", "code": "llm", "vision": "vision", "multimodal": "vision",
        "image": "image", "video": "video", "audio": "audio", "tts": "audio", "stt": "audio", "music": "audio",
        "embedding": "embedding", "embeddings": "embedding", "reranker": "embedding", "reranking": "embedding",
    }
    if value in aliases:
        return aliases[value], "declared"
    meta = " ".join(str(value).lower() for value in (metadata or {}).values())
    meta_patterns = (("audio", ("text-to-speech", "tts", "audio", "vocoder")),
        ("video", ("video", "diffusion transformer video")), ("image", ("image", "diffusion transformer image")),
        ("embedding", ("embedding", "text encoder", "rerank")), ("vision", ("vision", "multimodal")),
        ("llm", ("language model", "llama", "qwen")))
    for kind, words in meta_patterns:
        if any(word in meta for word in words):
            return kind, "metadata"
    text = (name + " " + location).lower()
    patterns = (
        ("embedding", ("embed", "bge-", "e5-", "rerank", "umt5", "text_encoder", "text-encoder")),
        ("audio", ("qwen-tts", "qwen_tts", "audio_vae", "audio-vae", "whisper", "tts", "audio", "music", "bark", "parler", "wav2vec")),
        ("image", ("qwen-image", "qwen_image", "stable-diffusion", "sdxl", "flux", "controlnet")),
        ("video", ("video", "wan", "ltx", "hunyuanvideo", "vace")),
        ("image", ("unet", "vae", "diffusion_models")),
        ("vision", ("vision", "vl", "llava", "clip")),
        ("llm", ("llama", "qwen", "mistral", "gemma", "gpt", "deepseek", "coder", "phi", "mixtral")),
    )
    for kind, words in patterns:
        if any(word in text for word in words):
            return kind, "heuristic"
    return "unknown", "unknown"


def metric(value: Any, unit: str = "") -> dict[str, Any] | None:
    if isinstance(value, (int, float)) and value >= 0 and unit:
        return {"value": float(value), "unit": unit, "source": "runtime"}
    return None


def make_model(runtime: str, name: str, *, location: str = "", state: str = "installed", declared_kind: str = "", metadata: dict[str, str] | None = None,
               metric_value: Any = None, metric_unit: str = "", memory: dict[str, Any] | None = None,
               activity: bool = False, capabilities: dict[str, bool] | None = None, detail: str = "",
               evidence: dict[str, Any] | None = None) -> dict[str, Any]:
    kind, confidence = classify(name, declared_kind, metadata, location)
    return {
        "id": model_id(runtime, name, location), "runtime": runtime, "name": name, "location": location or None,
        "kind": kind, "classificationConfidence": confidence, "state": state if state in VALID_STATES else "unknown",
        "activity": bool(activity), "metric": metric(metric_value, metric_unit), "memory": memory or {},
        "capabilities": capabilities or {"mount": False, "unmount": False, "releaseRuntime": False, "stopRuntime": False},
        "detail": detail, "evidence": evidence or {},
    }


DRIVERS = builtin_drivers({"request_json": lambda *args, **kwargs: request_json(*args, **kwargs), "safe_name": safe_name,
                           "make_model": make_model, "LocalAIError": LocalAIError})
# Compatibility names keep the small, testable adapters callable without
# restoring their implementation to this policy module.
models_from_llama = DRIVERS["llama_cpp"]
models_from_ollama = DRIVERS["ollama"]
models_from_lm_studio = DRIVERS["lm_studio"]
models_from_comfyui = DRIVERS["comfyui"]
models_from_vllm = DRIVERS["vllm"]


def driver_registry(config: dict[str, Any]) -> dict[str, Any]:
    registry = dict(DRIVERS)
    registry.update(descriptor_drivers(config, {"request_json": lambda *args, **kwargs: request_json(*args, **kwargs),
        "safe_name": safe_name, "make_model": make_model}))
    return registry


def configured_roots(config: dict[str, Any], runtimes: Iterable[Runtime]) -> list[Path]:
    values = list(config.get("roots", [])) + list(config.get("knownRoots", []))
    for runtime in runtimes:
        values.extend(str(root) for root in runtime.roots)
    roots, seen = [], set()
    for value in values:
        if not isinstance(value, str):
            continue
        root = Path(value).expanduser()
        if root not in seen and root.is_dir():
            roots.append(root)
            seen.add(root)
    return roots


def discover_files(config: dict[str, Any], runtimes: Iterable[Runtime], issues: list[dict[str, str]]) -> list[dict[str, Any]]:
    depth = max(0, min(8, int(config.get("scanDepth", 3))))
    found, seen = [], set()
    for root in configured_roots(config, runtimes):
        try:
            for directory, child_dirs, filenames in os.walk(root):
                relative = Path(directory).relative_to(root)
                if len(relative.parts) > depth:
                    child_dirs[:] = []
                    continue
                if len(relative.parts) == depth:
                    child_dirs[:] = []
                for filename in filenames:
                    path = Path(directory) / filename
                    if path.suffix.lower() not in MODEL_SUFFIXES:
                        continue
                    location = str(path)
                    if location in seen:
                        continue
                    seen.add(location)
                    metadata, metadata_issue = metadata_strings(path)
                    if metadata_issue:
                        issues.append({"kind": "metadata", "path": location, "detail": metadata_issue})
                    owner = next((runtime.id for runtime in runtimes if any(path.is_relative_to(root) for root in runtime.roots)), "filesystem")
                    found.append(make_model(owner, path.stem, location=location, state="installed", metadata=metadata,
                                            detail="discovered file"))
        except PermissionError:
            issues.append({"kind": "scan", "path": str(root), "detail": "permission denied"})
    return found


def observed_gpu_processes(config: dict[str, Any], run: Any = subprocess.run, proc_root: Path = Path("/proc")) -> list[dict[str, Any]]:
    """Expose GPU compute processes without claiming control over them.

    This is deliberately best effort.  An unavailable NVIDIA utility or an
    unreadable process is normal on machines without NVIDIA hardware and never
    turns a status refresh into an error.
    """
    if config.get("observeGpuProcesses", True) is False:
        return []
    try:
        completed = run(["nvidia-smi", "--query-compute-apps=pid", "--format=csv,noheader,nounits"],
                        text=True, capture_output=True, check=False)
    except (OSError, subprocess.SubprocessError):
        return []
    if completed.returncode != 0:
        return []
    models: list[dict[str, Any]] = []
    for raw_pid in completed.stdout.splitlines():
        pid = raw_pid.strip()
        if not pid.isdigit():
            continue
        process = proc_root / pid
        try:
            command = (process / "cmdline").read_bytes().replace(b"\0", b" ").decode("utf-8", errors="replace").strip()
            files = [str(link.resolve()) for link in (process / "fd").iterdir() if link.is_symlink()]
        except (OSError, PermissionError):
            continue
        evidence = {"pid": int(pid), "cmdline": command[:500], "openFiles": files[:12]}
        label = Path(command.split()[0]).name if command else f"GPU process {pid}"
        models.append(make_model("unknown_process", label or f"GPU process {pid}", location=" ".join(files), state="loaded",
            detail="GPU process observed, activity unknown", evidence=evidence,
            capabilities={"mount": False, "unmount": False, "releaseRuntime": False, "stopRuntime": False}))
    return models


def inventory(config: dict[str, Any]) -> dict[str, Any]:
    runtimes, models, issues = runtime_list(config), [], []
    runtime_states = []
    for runtime in runtimes:
        if not runtime.enabled:
            runtime_states.append({"id": runtime.id, "state": "disabled", "capabilities": {}})
            continue
        driver = driver_registry(config).get(runtime.id)
        if driver is None:
            runtime_states.append({"id": runtime.id, "state": "unknown", "capabilities": {}, "detail": "no driver"})
            continue
        try:
            items, state = driver(runtime)
            state.setdefault("capabilities", {})["stopRuntime"] = bool(re.fullmatch(r"[A-Za-z0-9@_.-]+\.service", runtime.service))
            if state["capabilities"]["stopRuntime"]:
                state.setdefault("stopImpact", "Stops the configured user service after its runtime is idle.")
            models.extend(items)
            runtime_states.append(state)
        except LocalAIError as error:
            runtime_states.append({"id": runtime.id, "state": "disconnected", "capabilities": {}, "detail": str(error)})
    runtime_names = {re.sub(r"[^a-z0-9]+", "", item["name"].lower()) for item in models}
    for item in discover_files(config, runtimes, issues):
        if re.sub(r"[^a-z0-9]+", "", item["name"].lower()) not in runtime_names:
            models.append(item)
    models.extend(observed_gpu_processes(config))
    # Stable order makes QML history and keyboard focus deterministic.
    models.sort(key=lambda item: (VALID_KINDS.index(item["kind"]), item["name"].lower(), item["runtime"]))
    return {"schemaVersion": 1, "generatedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            "refreshSeconds": max(5, min(3600, int(config.get("refreshSeconds", 15)))), "models": models,
            "runtimes": runtime_states, "issues": issues}


def find_runtime(config: dict[str, Any], runtime_id: str) -> Runtime:
    for runtime in runtime_list(config):
        if runtime.id == runtime_id and runtime.enabled:
            return runtime
    raise LocalAIError("runtime is not configured or is disabled")


def runtime_models(runtime: Runtime) -> list[dict[str, Any]]:
    driver = DRIVERS.get(runtime.id)
    if driver is None:
        raise LocalAIError("runtime has no control driver")
    return driver(runtime)[0]


def ensure_not_active(runtime: Runtime, model_key: str = "") -> str:
    models = runtime_models(runtime)
    active = [item for item in models if item.get("state") == "active"]
    if active:
        names = ", ".join(item["name"] for item in active)
        raise LocalAIError(f"action rejected while requests are active: {names}")
    if not model_key:
        return ""
    for item in models:
        if item["id"] == model_key or item["name"] == model_key:
            return item["name"]
    raise LocalAIError("model disappeared before the action")


def ensure_runtime_idle(runtime: Runtime) -> None:
    """Run each runtime's truthful activity probe before global control."""
    if runtime.id == "comfyui":
        queue = request_json(runtime.endpoint + "/queue")
        if isinstance(queue, dict) and (queue.get("queue_running") or queue.get("queue_pending")):
            raise LocalAIError("action rejected while ComfyUI has running or pending work")
        return
    ensure_not_active(runtime)


def validated_user_service(runtime: Runtime) -> None:
    if not re.fullmatch(r"[A-Za-z0-9@_.-]+\.service", runtime.service):
        raise LocalAIError("this runtime has no validated user systemd service")
    try:
        inspected = subprocess.run(["systemctl", "--user", "show", runtime.service, "--property", "LoadState", "--value"],
                                   text=True, capture_output=True, check=False)
    except OSError as error:
        raise LocalAIError("systemd user service inspection failed") from error
    if inspected.returncode != 0 or inspected.stdout.strip().lower() != "loaded":
        raise LocalAIError("this runtime has no validated user systemd service")


def action(config: dict[str, Any], command: str, runtime_id: str, model_key: str = "", confirmed: bool = False) -> dict[str, Any]:
    runtime = find_runtime(config, runtime_id)
    runtime_model = ensure_not_active(runtime, model_key if command in {"mount", "unmount"} else "")
    if command == "mount" and runtime.id == "llama_cpp":
        request_json(runtime.endpoint + "/models/load", "POST", {"model": runtime_model})
    elif command == "unmount" and runtime.id == "llama_cpp":
        request_json(runtime.endpoint + "/models/unload", "POST", {"model": runtime_model})
    elif command == "unmount" and runtime.id == "ollama":
        request_json(runtime.endpoint + "/api/generate", "POST", {"model": runtime_model, "keep_alive": 0})
    elif command == "release" and runtime.id == "comfyui":
        if not confirmed:
            raise LocalAIError("release affects every ComfyUI resident model and requires --confirm")
        queue = request_json(runtime.endpoint + "/queue")
        if queue.get("queue_running") or queue.get("queue_pending"):
            raise LocalAIError("action rejected while ComfyUI has running or pending work")
        request_json(runtime.endpoint + "/free", "POST", {"unload_models": True, "free_memory": True})
    elif command == "stop":
        if not confirmed:
            raise LocalAIError("stop requires --confirm")
        ensure_runtime_idle(runtime)
        validated_user_service(runtime)
        completed = subprocess.run(["systemctl", "--user", "stop", runtime.service], text=True, capture_output=True, check=False)
        if completed.returncode != 0:
            raise LocalAIError("systemd could not stop the configured runtime service")
    else:
        raise LocalAIError("action is not supported by this runtime")
    return {"ok": True, "action": command, "runtime": runtime.id, "model": model_key or None, "inventory": inventory(config)}


def parser() -> argparse.ArgumentParser:
    result = argparse.ArgumentParser(description="Inspect and safely control local AI runtimes.")
    result.add_argument("--config", help="JSON configuration file")
    result.add_argument("--version", action="version", version=VERSION)
    sub = result.add_subparsers(dest="command", required=True)
    sub.add_parser("status", help="Print the normalized inventory as JSON")
    sub.add_parser("opencode-catalog", help="Print an OpenCode-compatible local provider block without writing files")
    for name in ("mount", "unmount"):
        item = sub.add_parser(name)
        item.add_argument("runtime")
        item.add_argument("model", help="Runtime model id or normalized model id")
    item = sub.add_parser("release", help="Release every model held by one runtime when supported")
    item.add_argument("runtime")
    item.add_argument("--confirm", action="store_true")
    item = sub.add_parser("stop", help="Stop a runtime only through a safe runtime API")
    item.add_argument("runtime")
    item.add_argument("--confirm", action="store_true")
    return result


def opencode_catalog(config: dict[str, Any]) -> dict[str, Any]:
    runtime = find_runtime(config, "llama_cpp")
    models = runtime_models(runtime)
    names = [item["name"] for item in models]
    return {"provider": {"local-router": {"npm": "@ai-sdk/openai-compatible", "name": "Local llama.cpp router",
        "options": {"baseURL": runtime.endpoint + "/v1"}, "models": {name: {} for name in names}}}}


def main(argv: list[str] | None = None) -> int:
    args = parser().parse_args(argv)
    try:
        config = load_config(config_path(args.config))
        if args.command == "status":
            payload = inventory(config)
        elif args.command == "opencode-catalog":
            payload = opencode_catalog(config)
        else:
            payload = action(config, args.command, args.runtime, getattr(args, "model", ""), getattr(args, "confirm", False))
        print(json.dumps(payload, ensure_ascii=False, sort_keys=True))
        return 0
    except LocalAIError as error:
        print(json.dumps({"ok": False, "error": str(error), "command": args.command}, ensure_ascii=False), file=sys.stdout)
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
