    before: str
    success: bool
    detail: str
    after: str


def version_of(executable: str, language: str) -> str:
    try:
        result = subprocess.run([executable, "--version"], text=True, capture_output=True, check=False)
    except OSError as error:
        return message(language, "not_available", detail=error)
    if result.returncode != 0:
        detail = (result.stderr or result.stdout).strip() or f"code {result.returncode}"
        return message(language, "not_available", detail=detail)
    return (result.stdout or result.stderr).strip() or message(language, "no_output")


def build_update_command(provider: str) -> list[str]:
    return [command_name(provider), "update"]


def parse_update_list(value: str, language: str) -> list[str]:
    provider_options = providers(language)
    normalized = value.strip().lower()
    if normalized == "all":
        return [option.value for option in provider_options]
    requested = [item.strip().lower() for item in value.split(",")]
    if not requested or any(not item or item not in option_values(provider_options) for item in requested):
        die(language, "update_list_invalid", value=value, valid=", ".join(option.value for option in provider_options))
    selected = set(requested)
    return [option.value for option in provider_options if option.value in selected]


def run_updates(provider_ids: Sequence[str], dry_run: bool, language: str) -> int:
    if not provider_ids:
        return 0
    if dry_run:
        for provider in provider_ids:
            print(shlex.join(build_update_command(provider)))
        return 0
    labels = {option.value: option.label for option in providers(language)}
    results: list[UpdateResult] = []
    for provider in provider_ids:
        command = build_update_command(provider)
        before = version_of(command[0], language)
        try:
            result = subprocess.run(command, check=False)
        except OSError as error:
            success = False
            detail = message(language, "run_failed", error=error)
        else:
            success = result.returncode == 0
            detail = message(language, "success") if success else message(language, "failed_code", code=result.returncode)
        after = version_of(command[0], language)
        results.append(UpdateResult(provider, before, success, detail, after))
        print(f"{labels[provider]}: {message(language, 'previous_version')}: {before}")
        print(f"{labels[provider]}: {message(language, 'result')}: {detail}")
        print(f"{labels[provider]}: {message(language, 'new_version')}: {after}")
    print(message(language, "update_summary"))
    for record in results:
        status = message(language, "success") if record.success else message(language, "failed")
        print(f"{labels[record.provider]}: {status}")
    return 0 if all(record.success for record in results) else 1


def requested_language(argv: Sequence[str]) -> str:
    detected = locale_language()
    override: str | None = None
    for index, argument in enumerate(argv):
        if argument == "--language":
            if index + 1 >= len(argv):
                die(detected, "invalid_arguments")
            override = argv[index + 1]
        elif argument.startswith("--language="):
            override = argument.split("=", 1)[1]
    if override is None:
        return detected
    if override not in TRANSLATIONS:
        die(detected, "invalid_field", field="language", value=override, valid="en, es")
    return override


class LocalizedArgumentParser(argparse.ArgumentParser):
    def __init__(self, language: str, **kwargs: object) -> None:
        super().__init__(**kwargs)
        self.language = language

    def error(self, _message: str) -> NoReturn:
        self.print_usage(sys.stderr)
        die(self.language, "invalid_arguments")

    def format_help(self) -> str:
        output = super().format_help()
        if self.language == "es":
            output = output.replace("usage:", "uso:", 1)
            output = output.replace("\noptions:\n", "\nopciones:\n", 1)
            output = output.replace("\npositional arguments:\n", "\nargumentos posicionales:\n", 1)
        return output


def parse_arguments(language: str) -> argparse.Namespace:
    parser = LocalizedArgumentParser(
        language,
        prog="ai",
        description=message(language, "help_description"),
        epilog=message(language, "help_recover"),
        add_help=False,
    )
    parser.add_argument("-h", "--help", action="help", help=message(language, "help_help"))
    parser.add_argument("--version", action="version", version=f"ai-cli-control {VERSION}", help=message(language, "help_version"))
    parser.add_argument("--dry-run", action="store_true", help=message(language, "help_dry_run"))
    parser.add_argument("--text", action="store_true", help=message(language, "help_text"))
    parser.add_argument("--language", metavar="LANGUAGE", help=message(language, "help_language"))
    parser.add_argument("--provider", help=argparse.SUPPRESS)
    parser.add_argument("--model", help=argparse.SUPPRESS)
    parser.add_argument("--effort", help=argparse.SUPPRESS)
    parser.add_argument("--permissions", help=argparse.SUPPRESS)
    parser.add_argument("--update", metavar="LIST", help=message(language, "help_update"))
    return parser.parse_args()


def run_recover(arguments: Sequence[str]) -> int:
    """Run the standalone recovery engine located beside the real ai script."""
    recover = Path(__file__).resolve().with_name("recover.py")
    command = [sys.executable, str(recover), *(arguments or ("--help",))]
    try:
        return subprocess.run(command, check=False).returncode
    except KeyboardInterrupt:
        return 130


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] == "recover":
        return run_recover(sys.argv[2:])
    language = requested_language(sys.argv[1:])
    args = parse_arguments(language)
    if args.update is not None:
        return run_updates(parse_update_list(args.update, language), args.dry_run, language)
    ui = select_ui(args.text, language)
    provider_options = providers(language)
    try:
        if args.provider is None:
            provider = ui.choose("ai", message(language, "provider_prompt"), [*provider_options, update_option(language)])
        else:
            provider = choose_or_validate(ui, args.provider, "ai", message(language, "provider_prompt"), provider_options, "field_provider", language)
        if provider == update_option(language).value:
            selected = ui.choose_many(message(language, "update_title"), message(language, "update_prompt"), provider_options)
            return run_updates(selected, args.dry_run, language)
        if provider == "codex":
            models, codex_efforts = load_codex_models(language)
        elif provider == "claude":
            models = claude_models(language)
        elif provider == "grok":
            models = load_grok_models(language)
        else:
            models = load_antigravity_models(language)
        model = choose_or_validate(ui, args.model, "ai", message(language, "model_prompt"), models, "field_model", language)
        if provider == "codex":
            efforts = codex_efforts.get(model)
            if not efforts:
                die(language, "codex_efforts_empty", model=model)
        elif provider == "claude":
            efforts = [Option(value, value) for value in ("low", "medium", "high", "xhigh", "max")]
        elif provider == "grok":
            efforts = [Option(value, value) for value in ("low", "medium", "high")]
        else:
            if args.effort not in {None, "included"}:
                die(language, "antigravity_effort", value=args.effort)
            effort = "included"
        if provider != "antigravity":
            effort = choose_or_validate(ui, args.effort, "ai", message(language, "effort_prompt"), efforts, "field_effort", language)
        permission = choose_or_validate(ui, args.permissions, "ai", message(language, "permission_prompt"), permissions(language)[provider], "field_permission", language)
    except Cancelled:
        return 0
    command = build_command(provider, model, effort, permission)
    if args.dry_run:
        print(shlex.join(command))
        return 0
    executable = command[0]
    if os.path.sep not in executable and shutil.which(executable) is None:
        die(language, "executable_missing_path", executable=executable)
    if os.path.sep in executable and not os.access(executable, os.X_OK):
        die(language, "executable_missing_file", executable=executable)
    os.execvp(executable, command)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
