#!/usr/bin/env python3
"""Compact KodexBar quota output for Waybar and XFCE Generic Monitor."""

from __future__ import annotations

import argparse
import json
import math
import os
from pathlib import Path
import shutil
import subprocess
import sys
from typing import Any


ENGINE_TIMEOUT_SECONDS = 20
DEFAULT_TOOLTIP_LINES = 12
PALETTE = {
    "ok": "#35d07f",
    "warning": "#f5a623",
    "critical": "#ff5c5c",
}
LABELS = {
    "codex": "Cx",
    "claude": "Cl",
    "grok": "Gk",
    "antigravity": "Ag",
    "gemini": "Gm",
}


def provider_id(value: Any) -> str:
    return str(value or "").strip().lower()


def normalize_providers(value: str | None) -> list[str]:
    """Match the widget's case-insensitive, ordered de-duplication rules."""
    selected: list[str] = []
    seen: set[str] = set()
    for raw_id in str(value or "").split(","):
        identifier = provider_id(raw_id)
        if not identifier or identifier in seen:
            continue
        selected.append(identifier)
        seen.add(identifier)
    return selected


def provider_label(identifier: str, name: Any = None) -> str:
    if identifier in LABELS:
        return LABELS[identifier]
    fallback = str(name or identifier or "AI").strip()
    return fallback if len(fallback) <= 2 else fallback[:2]


def compact_percent(value: Any) -> int | None:
    if not isinstance(value, (int, float)) or isinstance(value, bool) or not math.isfinite(value):
        return None
    return int(math.floor(max(0.0, min(100.0, float(value))) + 0.5))


def usage_severity(values: list[float]) -> str:
    worst = max(values) if values else None
    if worst is not None and worst >= 80:
        return "critical"
    if worst is not None and worst >= 50:
        return "warning"
    return "ok"


def short_error(value: Any) -> str:
    text = " ".join(str(value or "quota data is unavailable").split())
    return text[:160] or "quota data is unavailable"


def window(entry: dict[str, Any], key: str) -> tuple[int | None, str | None, float | None]:
    usage = entry.get("usage")
    raw_window = usage.get(key) if isinstance(usage, dict) else None
    if not isinstance(raw_window, dict):
        return None, None, None
    raw_percent = raw_window.get("usedPercent")
    if not isinstance(raw_percent, (int, float)) or isinstance(raw_percent, bool) or not math.isfinite(raw_percent):
        percent = None
        severity_percent = None
    else:
        severity_percent = max(0.0, min(100.0, float(raw_percent)))
        percent = compact_percent(severity_percent)
    reset = raw_window.get("resetsAt")
    return percent, str(reset) if isinstance(reset, str) and reset else None, severity_percent


def antigravity_quotas(entry: dict[str, Any]) -> list[dict[str, Any]]:
    usage = entry.get("usage")
    raw_items = usage.get("antigravityRateWindows") if isinstance(usage, dict) else None
    if not isinstance(raw_items, list):
        return []
    labels = {
        "gemini-weekly": "GW",
        "gemini-5h": "G5h",
        "claude-gpt-weekly": "CW",
        "claude-gpt-5h": "C5h",
    }
    quotas = []
    for item in raw_items:
        if not isinstance(item, dict) or not isinstance(item.get("window"), dict):
            continue
        key = str(item.get("key") or "").strip().lower()
        percent, reset, raw = window({"usage": {"quota": item["window"]}}, "quota")
        quotas.append({
            "key": key or "upstream",
            "label": labels.get(key, str(item.get("title") or "Quota")),
            "title": str(item.get("title") or "Upstream quota"),
            "percentage": percent,
            "reset": reset,
            "raw_percentage": raw,
        })
    return quotas


def error_message(entry: dict[str, Any]) -> str | None:
    error = entry.get("error")
    if not isinstance(error, dict):
        return None
    message = error.get("message")
    return short_error(message) if message is not None else "quota data is unavailable"


def compact_provider(entry: Any) -> dict[str, Any] | None:
    if not isinstance(entry, dict):
        return None
    identifier = provider_id(entry.get("provider"))
    if not identifier:
        return None
    error = error_message(entry)
    quotas = antigravity_quotas(entry) if identifier == "antigravity" else []
    session, session_reset, session_raw = window(entry, "primary")
    weekly, weekly_reset, weekly_raw = window(entry, "secondary")
    severity_values = [item["raw_percentage"] for item in quotas] if quotas else [session_raw, weekly_raw]
    severity = "critical" if error else usage_severity([value for value in severity_values if value is not None])
    result = {
        "provider": identifier,
        "label": provider_label(identifier, entry.get("name")),
        "percentages": {"session": session, "weekly": weekly},
        "resets": {"session": session_reset, "weekly": weekly_reset},
        "severity": severity,
        "error": error is not None,
        "error_message": error,
    }
    if quotas:
        result["quotas"] = quotas
        result["percentages"] = {}
        result["resets"] = {}
    return result


def select_entries(entries: list[Any], providers: list[str]) -> list[Any]:
    if not providers:
        return entries
    selected: list[Any] = []
    for requested in providers:
        selected.extend(
            entry for entry in entries
            if isinstance(entry, dict) and provider_id(entry.get("provider")) == requested
        )
    return selected


def block_text(provider: dict[str, Any]) -> str:
    parts = [provider["label"]]
    if provider["error"]:
        parts.append("ERR")
    else:
        if provider.get("quotas"):
            for quota in provider["quotas"]:
                if quota["percentage"] is not None:
                    parts.append(f'{quota["label"]} {quota["percentage"]}%')
            return " ".join(parts)
        session = provider["percentages"]["session"]
        weekly = provider["percentages"]["weekly"]
        if session is not None:
            parts.append(f"S {session}%")
        if weekly is not None:
            parts.append(f"W {weekly}%")
    return " ".join(parts)


def pango_escape(value: Any) -> str:
    return str(value).replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;")


def pango_text(providers: list[dict[str, Any]]) -> str:
    return " | ".join(
        f'<span foreground="{PALETTE[provider["severity"]]}">{pango_escape(block_text(provider))}</span>'
        for provider in providers
    )


def tooltip_lines(providers: list[dict[str, Any]]) -> list[str]:
    lines: list[str] = []
    for provider in providers:
        title = f'{provider["label"]} ({provider["provider"]})'
        if provider["error"]:
            lines.append(f"{title}: ERR, {provider['error_message']}")
            continue
        known = False
        if provider.get("quotas"):
            for quota in provider["quotas"]:
                if quota["percentage"] is None and not quota["reset"]:
                    continue
                known = True
                detail = f'{title}: {quota["title"]}'
                if quota["percentage"] is not None:
                    detail += f' {quota["percentage"]}%'
                if quota["reset"]:
                    detail += f', resets {quota["reset"]}'
                lines.append(detail)
            if not known:
                lines.append(f"{title}: no Antigravity quotas reported")
            continue
        for key, title_key in (("session", "Session"), ("weekly", "Weekly")):
            percent = provider["percentages"][key]
            reset = provider["resets"][key]
            if percent is None and not reset:
                continue
            known = True
            detail = f"{title}: {title_key}"
            if percent is not None:
                detail += f" {percent}%"
            if reset:
                detail += f", resets {reset}"
            lines.append(detail)
        if not known:
            lines.append(f"{title}: no session or weekly usage reported")
    return lines


def compact_model(entries: list[Any], providers: list[str]) -> dict[str, Any]:
    compact = [provider for entry in select_entries(entries, providers) if (provider := compact_provider(entry))]
    text = " | ".join(block_text(provider) for provider in compact) or "No quota data"
    severity_order = {"ok": 0, "warning": 1, "critical": 2}
    severity = max((provider["severity"] for provider in compact), key=severity_order.get, default="ok")
    return {"providers": compact, "text": text, "class": severity}


def error_model(message: str) -> dict[str, Any]:
    return {
        "providers": [],
        "text": "Quota error",
        "class": "critical",
        "error": short_error(message),
    }


def engine_path() -> str | None:
    sibling = Path(__file__).resolve().with_name("kodexbar-quotas")
    if sibling.is_file() and os.access(sibling, os.X_OK):
        return str(sibling)
    return shutil.which("kodexbar-quotas")


def fetch_entries() -> tuple[list[Any] | None, str | None]:
    engine = engine_path()
    if engine is None:
        return None, "kodexbar-quotas is not installed"
    try:
        completed = subprocess.run(
            [engine, "usage", "--format", "json", "--provider", "all"],
            capture_output=True,
            text=True,
            timeout=ENGINE_TIMEOUT_SECONDS,
            check=False,
        )
    except subprocess.TimeoutExpired:
        return None, "kodexbar-quotas timed out"
    except OSError:
        return None, "kodexbar-quotas could not run"
    if completed.returncode != 0:
        return None, "kodexbar-quotas failed"
    try:
        payload = json.loads(completed.stdout)
    except json.JSONDecodeError:
        return None, "kodexbar-quotas returned invalid JSON"
    if isinstance(payload, dict):
        payload = [payload]
    if not isinstance(payload, list):
        return None, "kodexbar-quotas returned invalid quota data"
    return payload, None


def waybar_payload(model: dict[str, Any], maximum_lines: int) -> dict[str, str]:
    if model.get("error"):
        tooltip = pango_escape(f"KodexBar quotas unavailable: {model['error']}")
    else:
        lines = tooltip_lines(model["providers"])
        tooltip = "\n".join(pango_escape(line) for line in lines[:maximum_lines]) or "No quota data"
    return {"text": pango_escape(model["text"]), "tooltip": tooltip, "class": model["class"]}


def status_payload(model: dict[str, Any], maximum_lines: int) -> dict[str, Any]:
    """Return the tray-friendly status without changing legacy panel formats."""
    if model.get("error"):
        tooltip = f"KodexBar quotas unavailable: {model['error']}"
    else:
        tooltip = "\n".join(tooltip_lines(model["providers"])[:maximum_lines]) or "No quota data"
    return {
        "text": model["text"],
        "tooltip": tooltip,
        "class": model["class"],
        "providers": model["providers"],
    }


def waybar_snippet() -> str:
    return """// Add \"custom/kodexbar\" to modules-left, modules-center, or modules-right.\n\"custom/kodexbar\": {\n  \"exec\": \"kodexbar-panel --format waybar\",\n  \"return-type\": \"json\",\n  \"interval\": 60\n},\n\n// Add these rules to your Waybar CSS.\n// #custom-kodexbar.ok { color: #35d07f; }\n// #custom-kodexbar.warning { color: #f5a623; }\n// #custom-kodexbar.critical { color: #ff5c5c; }"""


def parse_arguments(arguments: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--format", choices=("waybar", "text", "json"), default="text")
    parser.add_argument("--status-json", action="store_true", help="print tray-friendly JSON status")
    parser.add_argument("--pango", action="store_true", help="color text provider blocks with Pango markup")
    parser.add_argument("--providers", default="", help="comma-separated provider IDs")
    parser.add_argument("--max-tooltip-lines", type=int, default=DEFAULT_TOOLTIP_LINES)
    parser.add_argument("--waybar-snippet", action="store_true", help="print a Waybar configuration snippet")
    parsed = parser.parse_args(arguments)
    if parsed.max_tooltip_lines < 1:
        parser.error("--max-tooltip-lines must be at least 1")
    return parsed


def main(arguments: list[str]) -> int:
    options = parse_arguments(arguments)
    if options.waybar_snippet:
        print(waybar_snippet())
        return 0
    entries, failure = fetch_entries()
    model = error_model(failure) if failure else compact_model(entries or [], normalize_providers(options.providers))
    if options.status_json:
        print(json.dumps(status_payload(model, options.max_tooltip_lines), ensure_ascii=False))
    elif options.format == "waybar":
        print(json.dumps(waybar_payload(model, options.max_tooltip_lines), ensure_ascii=False))
    elif options.format == "json":
        print(json.dumps(model, ensure_ascii=False))
    elif options.pango and not model.get("error"):
        print(pango_text(model["providers"]) or "No quota data")
    else:
        print(model["text"])
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
