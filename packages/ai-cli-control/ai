def load_codex_models(language: str) -> tuple[list[Option], dict[str, list[Option]]]:
    try:
        payload = json.loads(CODEX_CACHE.read_text(encoding="utf-8"))
        raw_models = payload["models"]
    except (OSError, json.JSONDecodeError, KeyError, TypeError) as error:
        die(language, "codex_cache_error", path=CODEX_CACHE, error=error)
    models: list[Option] = []
    efforts: dict[str, list[Option]] = {}
    for item in raw_models:
        if not isinstance(item, dict):
            continue
        slug = item.get("slug")
        if not isinstance(slug, str) or not slug:
            continue
        display = item.get("display_name") or slug
        description = item.get("description") or message(language, "codex_catalog")
        models.append(Option(slug, str(display), str(description)))
        parsed_levels = [
            Option(level["effort"], level["effort"], str(level.get("description") or ""))
            for level in item.get("supported_reasoning_levels", [])
            if isinstance(level, dict) and isinstance(level.get("effort"), str)
        ]
        if parsed_levels:
            efforts[slug] = parsed_levels
    if not models:
        die(language, "codex_catalog_empty", path=CODEX_CACHE)
    return models, efforts


def load_grok_models(language: str) -> list[Option]:
    executable = command_name("grok")
    try:
        result = subprocess.run([executable, "models"], text=True, capture_output=True, check=False, timeout=15)
    except (OSError, subprocess.TimeoutExpired) as error:
        die(language, "grok_query_error", error=error)
    if result.returncode != 0:
        detail = (result.stderr or result.stdout).strip() or f"code {result.returncode}"
        die(language, "grok_failed", detail=detail)
    models: list[Option] = []
    for line in result.stdout.splitlines():
        match = re.match(r"^\s*(?:\*|-)\s+([^\s]+)(?:\s+\(default\))?\s*$", line)
        if match:
            model = match.group(1)
            label = f"{model} ({message(language, 'default')})" if "(default)" in line else model
            models.append(Option(model, label, message(language, "grok_catalog")))
    if not models:
        die(language, "grok_empty")
    return models


def load_antigravity_models(language: str) -> list[Option]:
    executable = command_name("antigravity")
    try:
        result = subprocess.run([executable, "models"], text=True, capture_output=True, check=False, timeout=15)
    except (OSError, subprocess.TimeoutExpired) as error:
        die(language, "antigravity_query_error", error=error)
    if result.returncode != 0:
        detail = (result.stderr or result.stdout).strip() or f"code {result.returncode}"
        die(language, "antigravity_failed", detail=detail)
    models = [Option(line, line, message(language, "antigravity_catalog")) for line in result.stdout.splitlines() if line.strip()]
    if not models:
        die(language, "antigravity_empty")
    return models


def option_values(options: Sequence[Option]) -> set[str]:
    return {option.value for option in options}


def choose_or_validate(ui: SelectorUI, supplied: str | None, title: str, prompt: str, options: Sequence[Option], field: str, language: str) -> str:
    if supplied is None:
        return ui.choose(title, prompt, options)
    if supplied not in option_values(options):
        die(language, "invalid_field", field=message(language, field), value=supplied, valid=", ".join(option.value for option in options))
    return supplied


def permission_arguments(provider: str, permission: str) -> list[str]:
    if provider == "codex":
        return {
            "read-only": ["--sandbox", "read-only", "--ask-for-approval", "never"],
            "ask": ["--sandbox", "workspace-write", "--ask-for-approval", "on-request"],
            "automatic": ["--sandbox", "workspace-write", "--ask-for-approval", "never"],
            "full": ["--dangerously-bypass-approvals-and-sandbox"],
        }[permission]
    if provider in {"claude", "grok"}:
        mapping = {"plan": "plan", "manual": "manual", "default": "default", "accept-edits": "acceptEdits", "auto": "auto", "dont-ask": "dontAsk", "bypass": "bypassPermissions"}
        return ["--permission-mode", mapping[permission]]
    return {
        "manual": [], "plan": ["--mode", "plan"], "accept-edits": ["--mode", "accept-edits"],
        "sandbox": ["--sandbox"], "full": ["--dangerously-skip-permissions"],
    }[permission]


def build_command(provider: str, model: str, effort: str, permission: str) -> list[str]:
    command = [command_name(provider), "--model", model]
    if provider == "codex":
        command.extend(["--config", f'model_reasoning_effort="{effort}"'])
    elif provider == "claude":
        command.extend(["--effort", effort])
    elif provider == "grok":
        command.extend(["--reasoning-effort", effort])
    command.extend(permission_arguments(provider, permission))
    return command


