	optdepends = libayatana-appindicator: AppIndicator bindings for kodexbar-tray
	optdepends = wl-clipboard: Wayland clipboard support for ai recover --copy
	optdepends = xclip: X11 clipboard support for ai recover --copy
	optdepends = xsel: alternate X11 clipboard support for ai recover --copy
