class FetchFallback(Exception):
    """A native or upstream fetch failed with a classified cause."""

    def __init__(self, message: str, category: str = "permanent", retryable: bool = False):
        super().__init__(message)
        self.category = category
        self.retryable = retryable


def home_directory() -> Path:
    return Path(os.environ.get("HOME", str(Path.home()))).expanduser()


def codexbar_config_path(home: Path | None = None) -> Path:
    root = home or home_directory()
    return root / ".config" / "codexbar" / "config.json"


def read_json(path: Path) -> Any:
    with path.open(encoding="utf-8") as handle:
        return json.load(handle)


def enabled_providers(home: Path | None = None) -> list[str]:
    """Read the ordered enabled provider list from CodexBar's public config."""
    config = read_json(codexbar_config_path(home))
    if not isinstance(config, dict):
        raise ValueError("CodexBar config root must be a JSON object")
    providers = config.get("providers")
    if not isinstance(providers, list):
        raise ValueError("CodexBar config has no providers array")
    result = []
    for provider in providers:
        if not isinstance(provider, dict) or provider.get("enabled") is not True:
            continue
        provider_id = provider.get("id")
        if isinstance(provider_id, str) and provider_id:
            result.append(provider_id.lower())
    return result


def command_on_path(name: str) -> bool:
    """True when an executable named `name` is on PATH (local, no network)."""
    return shutil.which(name) is not None


def detect_claude_installed(home: Path | None = None) -> bool:
    """Claude is present when OAuth credentials are valid or `claude` is on PATH."""
    root = home or home_directory()
    return has_claude_credentials(root) or command_on_path("claude")


def detect_codex_installed(home: Path | None = None) -> bool:
    """Codex is present when auth.json exists or `codex` is on PATH."""
    root = home or home_directory()
    return (root / ".codex" / "auth.json").is_file() or command_on_path("codex")


def detect_grok_installed(home: Path | None = None) -> bool:
    """Grok is present when `grok` is on PATH or `~/.grok` exists."""
    root = home or home_directory()
    return command_on_path("grok") or (root / ".grok").is_dir()


def detect_antigravity_installed(home: Path | None = None) -> bool:
    """Antigravity is present when `agy` or `antigravity` is on PATH."""
    return command_on_path("agy") or command_on_path("antigravity")


def detect_installed_providers(home: Path | None = None) -> dict[str, bool]:
    """Local-only detection of installed provider CLIs/credentials (pure, testable)."""
    root = home or home_directory()
    return {
        "claude": detect_claude_installed(root),
        "codex": detect_codex_installed(root),
        "grok": detect_grok_installed(root),
        "antigravity": detect_antigravity_installed(root),
    }


def build_auto_config(detected: dict[str, bool]) -> dict[str, Any]:
    """CodexBar config payload: version 1 and all four provider ids, enabled only when detected."""
    return {
        "version": 1,
        "providers": [
            {"id": provider_id, "enabled": bool(detected.get(provider_id))}
            for provider_id in AUTO_CONFIG_PROVIDER_IDS
        ],
    }


def write_auto_config_atomic(config_path: Path, payload: dict[str, Any]) -> bool:
    """Publish config.json exclusively via tempfile + hard link.

    Returns True only when this call created config_path. If another process already
    published the file, returns False without altering the winner's content.
    """
    config_path.parent.mkdir(parents=True, exist_ok=True)
    text = json.dumps(payload, ensure_ascii=False)
    fd, tmp_name = tempfile.mkstemp(
        prefix=".config.",
        suffix=".tmp",
        dir=str(config_path.parent),
    )
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            handle.write(text)
            handle.flush()
            os.fsync(handle.fileno())
        try:
            # Exclusive publish: link fails with FileExistsError if the race is lost.
            os.link(tmp_name, config_path)
        except FileExistsError:
            return False
        return True
    except Exception:
        raise
    finally:
        try:
            os.unlink(tmp_name)
        except OSError:
            pass


def ensure_auto_config(home: Path | None = None) -> bool:
    """If config is absent and at least one CLI is detected, generate it once.

    Never overwrites an existing config (valid or malformed). Silent on stdout.
    Write failures are swallowed so the caller keeps the current absent-config path.
    Returns True when a config file was written successfully by this call.
    """
    root = home or home_directory()
    config_path = codexbar_config_path(root)
    if config_path.exists():
        return False
    detected = detect_installed_providers(root)
    if not any(detected.values()):
        return False
    try:
        return write_auto_config_atomic(config_path, build_auto_config(detected))
    except OSError:
        return False


def claude_access_token(home: Path | None = None) -> str:
    root = home or home_directory()
    try:
        credentials = read_json(root / ".claude" / ".credentials.json")
    except (OSError, json.JSONDecodeError) as error:
        raise FetchFallback("Claude OAuth credentials are unavailable", "authentication") from error
    if not isinstance(credentials, dict):
        raise FetchFallback("Claude OAuth credentials are unavailable", "authentication")
    oauth = credentials.get("claudeAiOauth")
    if not isinstance(oauth, dict):
        raise FetchFallback("Claude OAuth credentials are unavailable", "authentication")
    token = oauth.get("accessToken")
    if not isinstance(token, str) or not token.strip():
        raise FetchFallback("Claude OAuth credentials are unavailable", "authentication")
    return token.strip()


def has_claude_credentials(home: Path | None = None) -> bool:
    """True when local Claude OAuth credentials exist with a non-empty access token (no network)."""
    try:
        claude_access_token(home)
        return True
    except FetchFallback:
        return False


