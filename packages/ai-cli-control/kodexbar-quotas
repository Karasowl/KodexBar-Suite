def read_http_body_limited(stream: Any, max_bytes: int = HTTP_MAX_BODY_BYTES) -> bytes:
    """Read an HTTP body with a hard size cap. Excess becomes a parse error, not a hang."""
    chunks: list[bytes] = []
    total = 0
    while True:
        # Read one past the limit so we can detect overflow without unbounded buffering.
        to_read = min(65536, max_bytes + 1 - total)
        if to_read <= 0:
            break
        try:
            chunk = stream.read(to_read)
        except Exception:
            raise FetchFallback(HTTP_REQUEST_FAILED, "network", True)
        if not chunk:
            break
        total += len(chunk)
        if total > max_bytes:
            raise FetchFallback("HTTP response body exceeds size limit", "invalid_response", False)
        chunks.append(chunk)
    return b"".join(chunks)


def http_request(
    method: str,
    url: str,
    headers: dict[str, str] | None = None,
    body: bytes | None = None,
    timeout: float = TIMEOUT_SECONDS,
) -> tuple[int, dict[str, str], bytes]:
    """Injectable HTTP seam (stdlib urllib only). Never logs Authorization or bodies.

    Request construction and execution stay inside the try block so unexpected
    exceptions (for example header validation ValueError that embeds the header
    value) never escape with secrets. Generic failures become a fixed sanitized
    message with no exception chaining.
    """
    try:
        request_headers = dict(headers or {})
        request = Request(url, data=body, headers=request_headers, method=method.upper())
        with urlopen(request, timeout=timeout) as response:
            resp_headers = {str(k): str(v) for k, v in response.headers.items()}
            return int(response.status), resp_headers, read_http_body_limited(response)
    except HTTPError as error:
        resp_headers = {str(k): str(v) for k, v in (error.headers or {}).items()}
        try:
            payload = read_http_body_limited(error)
        except FetchFallback:
            payload = b""
        except Exception:
            payload = b""
        return int(error.code), resp_headers, payload
    except FetchFallback:
        raise
    except (URLError, OSError, TimeoutError) as error:
        category = (
            "timeout"
            if isinstance(error, TimeoutError) or "timed out" in str(error).lower()
            else "network"
        )
        # Do not include request headers/body (may contain secrets). Chain only
        # classified transport failures, never raw header-validation errors.
        raise FetchFallback(f"HTTP {category} failure for {method.upper()}", category, True) from error
    except Exception:
        # Fixed message only. Never str(e) and never `from e` (header values leak).
        raise FetchFallback(HTTP_REQUEST_FAILED, "network", True)


def http_get(url: str, headers: dict[str, str]) -> tuple[int, bytes]:
    """Claude-compat wrapper around http_request (keeps legacy tests and fixture)."""
    if os.environ.get("KODEXBAR_QUOTAS_FIXTURE_429") == "1":
        return 429, b"{}"
    try:
        status, _resp_headers, body = http_request("GET", url, headers, None, TIMEOUT_SECONDS)
    except FetchFallback as error:
        # Preserve Claude-specific wording expected by existing tests and users.
        raise FetchFallback(
            f"Claude OAuth {error.category} failure: {error}",
            error.category,
            error.retryable,
        ) from error
    return status, body


def iso_now() -> str:
    return datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z")


def unix_seconds_to_iso(seconds: int | float) -> str:
    return (
        datetime.fromtimestamp(int(seconds), tz=timezone.utc)
        .replace(microsecond=0)
        .isoformat()
        .replace("+00:00", "Z")
    )


def usage_window(value: Any, minutes: int) -> dict[str, Any] | None:
    if not isinstance(value, dict):
        return None
    utilization = value.get("utilization")
    if not isinstance(utilization, (int, float)):
        return None
    window: dict[str, Any] = {
        "usedPercent": utilization,
        "windowMinutes": minutes,
    }
    resets_at = value.get("resets_at")
    if isinstance(resets_at, str) and resets_at:
        window["resetsAt"] = resets_at
    return window


def _coerce_finite_number(value: Any) -> float | None:
    """Finite float from int/float/numeric string. Bools and non-numeric values are None."""
    if isinstance(value, bool):
        return None
    if isinstance(value, (int, float)):
        try:
            number = float(value)
        except (OverflowError, ValueError, TypeError):
            return None
        return number if math.isfinite(number) else None
    if isinstance(value, str):
        text = value.strip()
        if not text:
            return None
        try:
            number = float(text)
        except (OverflowError, ValueError, TypeError):
            return None
        return number if math.isfinite(number) else None
    return None


def map_claude_extra_usage(extra_usage: Any) -> dict[str, Any]:
    """Map Claude extra_usage block. Always emit enabled/balance/currency (balance may be None).

    ``balance`` is remaining dollars only, never consumption (``used_credits``).
    Prefer an explicit remaining/balance field from the API; otherwise
    ``monthly_limit - used_credits`` when both are numeric and the result is >= 0.
    """
    if not isinstance(extra_usage, dict):
        return {"enabled": False, "balance": None, "currency": None}
    enabled = bool(extra_usage.get("is_enabled"))
    monthly_n = _coerce_finite_number(extra_usage.get("monthly_limit"))
    used_n = _coerce_finite_number(extra_usage.get("used_credits"))
    # Explicit remaining/balance keys (if Anthropic ships them) win over derivation.
    explicit_remaining: float | None = None
    for key in ("remaining", "balance", "remaining_credits", "credits_remaining"):
        candidate = _coerce_finite_number(extra_usage.get(key))
        if candidate is not None:
            explicit_remaining = candidate
            break
    balance: float | None = None
    if explicit_remaining is not None and explicit_remaining >= 0:
        balance = explicit_remaining
    elif monthly_n is not None and used_n is not None:
        remaining = monthly_n - used_n
        if remaining >= 0:
            balance = remaining
    # used_credits alone is consumption, never remaining balance.
    currency = extra_usage.get("currency")
    if not isinstance(currency, str) or not currency:
        currency = None
    return {"enabled": enabled, "balance": balance, "currency": currency}


def _claude_limit_window(item: dict[str, Any], minutes: int) -> dict[str, Any] | None:
    percent = item.get("percent")
    if not isinstance(percent, (int, float)) or isinstance(percent, bool):
        return None
    try:
        used = float(percent)
    except (OverflowError, ValueError, TypeError):
        return None
    if not math.isfinite(used):
        return None
    window: dict[str, Any] = {"usedPercent": used, "windowMinutes": minutes}
    resets_at = item.get("resets_at")
    if isinstance(resets_at, str) and resets_at:
        window["resetsAt"] = resets_at
    return window


def map_claude_usage_from_limits(limits: list[Any]) -> dict[str, Any] | None:
    """Map self-describing limits[] (session / weekly_all / weekly_scoped). None → use legacy keys."""
    primary: dict[str, Any] | None = None
    secondary: dict[str, Any] | None = None
    extras: list[dict[str, Any]] = []
    for item in limits:
        if not isinstance(item, dict):
            continue
        kind = item.get("kind")
        if kind == "session":
            mapped = _claude_limit_window(item, 300)
            if mapped is not None:
                primary = mapped
        elif kind == "weekly_all":
            mapped = _claude_limit_window(item, 10080)
            if mapped is not None:
                secondary = mapped
        elif kind == "weekly_scoped":
            mapped = _claude_limit_window(item, 10080)
            if mapped is None:
                continue
            scope = item.get("scope") if isinstance(item.get("scope"), dict) else {}
            model = scope.get("model") if isinstance(scope.get("model"), dict) else {}
            title = model.get("display_name")
            if not isinstance(title, str) or not title:
                continue
            window = {
                "usedPercent": mapped["usedPercent"],
                "usageKnown": True,
            }
            if "resetsAt" in mapped:
                window["resetsAt"] = mapped["resetsAt"]
            extras.append({"title": title, "window": window})
    if primary is None and secondary is None and not extras:
        return None
    return {
        "primary": primary,
        "secondary": secondary,
        "tertiary": None,
        "extraRateWindows": extras,
    }


def map_claude_usage(payload: Any, updated_at: str | None = None) -> dict[str, Any]:
    """Map Anthropic OAuth fields to the CodexBar CLI JSON envelope.

    Prefer self-describing ``limits[]`` (session, weekly_all, weekly_scoped models such as Fable).
    Fall back to legacy five_hour / seven_day / seven_day_sonnet keys for older payloads.
    Always emit ``extraUsage``. Never emit top-level ``credits`` (extra usage is the balance line).
    """
    if not isinstance(payload, dict):
        raise FetchFallback("Claude OAuth returned an invalid response", "invalid_response", True)

    primary: dict[str, Any] | None = None
    secondary: dict[str, Any] | None = None
    tertiary: dict[str, Any] | None = None
    extras: list[dict[str, Any]] = []

    limits = payload.get("limits")
    mapped_limits = (
        map_claude_usage_from_limits(limits) if isinstance(limits, list) and limits else None
    )
    if mapped_limits is not None:
        primary = mapped_limits["primary"]
        secondary = mapped_limits["secondary"]
        tertiary = mapped_limits["tertiary"]
        extras = list(mapped_limits.get("extraRateWindows") or [])
        if primary is None and secondary is None and not extras:
            raise FetchFallback("Claude OAuth response has no usage window", "invalid_response", True)
    else:
        primary = usage_window(payload.get("five_hour"), 300)
        fallback_keys = ("seven_day", "seven_day_oauth_apps", "seven_day_sonnet", "seven_day_opus")
        if primary is None:
            for key in fallback_keys:
                primary = usage_window(payload.get(key), 10080)
                if primary is not None:
                    break
        if primary is None:
            raise FetchFallback("Claude OAuth response has no usage window", "invalid_response", True)
        secondary = usage_window(payload.get("seven_day"), 10080)
        tertiary = usage_window(payload.get("seven_day_sonnet"), 10080)
        if tertiary is None:
            tertiary = usage_window(payload.get("seven_day_opus"), 10080)

    usage: dict[str, Any] = {
        "identity": {"providerID": "claude"},
        "primary": primary,
        "secondary": secondary,
        "tertiary": tertiary,
        "extraUsage": map_claude_extra_usage(payload.get("extra_usage")),
        "updatedAt": updated_at or iso_now(),
    }
    if extras:
        usage["extraRateWindows"] = extras
    return {
        "provider": "claude",
        "source": "claude",
        "usage": usage,
        "engine": "kodexbar",
    }


def provider_error(
    provider: str,
    source: str,
    message: str,
    category: str = "permanent",
    retryable: bool = False,
) -> dict[str, Any]:
    return {
        "provider": provider,
        "source": source,
        "error": {
            "code": 1,
            "message": message,
            "kind": "provider",
            "category": category,
            "retryable": retryable,
        },
        "engine": "kodexbar",
    }


def fetch_claude(home: Path | None = None) -> dict[str, Any]:
    token = claude_access_token(home)
    status, body = http_get(
        CLAUDE_USAGE_URL,
        {
            "Authorization": f"Bearer {token}",
            "Accept": "application/json",
            "Content-Type": "application/json",
            "anthropic-beta": "oauth-2025-04-20",
            "User-Agent": "claude-code/2.1.0",
        },
    )
    if status == 429:
        return provider_error(
            "claude",
            "claude",
            "Claude OAuth usage endpoint is rate limited by Anthropic right now. Wait a few minutes, then click Refresh.",
            "rate_limit",
        )
    if status == 401:
        return provider_error("claude", "claude", "Claude OAuth rejected the current credentials (HTTP 401)", "authentication")
    if status == 403:
        return provider_error("claude", "claude", "Claude OAuth denied access to usage data (HTTP 403)", "entitlement")
    if status != 200:
        retryable = status in (408, 425) or status >= 500
        category = "timeout" if status == 408 else ("network" if retryable else "permanent")
        raise FetchFallback(f"Claude OAuth usage request failed with HTTP {status}", category, retryable)
    try:
        return map_claude_usage(json.loads(body.decode("utf-8")))
    except (UnicodeDecodeError, json.JSONDecodeError) as error:
        raise FetchFallback("Claude OAuth returned invalid JSON", "invalid_response", True) from error


