@dataclass(frozen=True)
class Option:
    value: str
    label: str
    description: str = ""


class Cancelled(Exception):
    pass


def locale_language(environ: dict[str, str] | None = None) -> str:
    """Return Spanish only for an explicitly Spanish standard locale."""
    environment = os.environ if environ is None else environ
    for variable in ("LC_ALL", "LC_MESSAGES", "LANGUAGE", "LANG"):
        value = environment.get(variable, "")
        if value:
            return "es" if value.lower().startswith("es") else "en"
    return "en"


def message(language: str, key: str, **values: object) -> str:
    return TRANSLATIONS[language][key].format(**values)


class SelectorUI:
    def choose(self, title: str, prompt: str, options: Sequence[Option]) -> str:
        raise NotImplementedError

    def choose_many(self, title: str, prompt: str, options: Sequence[Option]) -> list[str]:
        raise NotImplementedError


class TextUI(SelectorUI):
    def __init__(self, language: str) -> None:
        self.language = language

    def choose(self, title: str, prompt: str, options: Sequence[Option]) -> str:
        print(f"\n{title}\n{prompt}", file=sys.stderr)
        for index, option in enumerate(options, start=1):
            detail = f". {option.description}" if option.description else ""
            print(f"  {index}) {option.label}{detail}", file=sys.stderr)
        print(f"  0) {message(self.language, 'cancel')}", file=sys.stderr)
        while True:
            try:
                print(message(self.language, "selection"), end="", file=sys.stderr, flush=True)
                answer = sys.stdin.readline()
            except KeyboardInterrupt:
                raise Cancelled from None
            if answer == "":
                raise Cancelled
            answer = answer.strip()
            if answer in {"0", "q", "Q"}:
                raise Cancelled
            if answer.isdigit() and 1 <= int(answer) <= len(options):
                return options[int(answer) - 1].value
            print(message(self.language, "invalid_selection"), file=sys.stderr)

    def choose_many(self, title: str, prompt: str, options: Sequence[Option]) -> list[str]:
        print(f"\n{title}\n{prompt}", file=sys.stderr)
        for index, option in enumerate(options, start=1):
            detail = f". {option.description}" if option.description else ""
            print(f"  {index}) {option.label}{detail}", file=sys.stderr)
        print(f"  0) {message(self.language, 'cancel')}", file=sys.stderr)
        print(message(self.language, "many_hint"), file=sys.stderr)
        while True:
            try:
                print(message(self.language, "selection"), end="", file=sys.stderr, flush=True)
                answer = sys.stdin.readline()
            except KeyboardInterrupt:
                raise Cancelled from None
            if answer == "":
                raise Cancelled
            answer = answer.strip()
            if answer in {"0", "q", "Q"}:
                raise Cancelled
            if answer == "":
                return []
            if answer.lower() == "all":
                return [option.value for option in options]
            try:
                indexes = [int(item.strip()) for item in answer.split(",")]
            except ValueError:
                indexes = []
            if indexes and all(1 <= index <= len(options) for index in indexes):
                selected = set(indexes)
                return [option.value for index, option in enumerate(options, start=1) if index in selected]
            print(message(self.language, "invalid_many"), file=sys.stderr)


class KDialogUI(SelectorUI):
    def __init__(self, language: str) -> None:
        self.language = language

    def choose(self, title: str, prompt: str, options: Sequence[Option]) -> str:
        command = ["kdialog", "--title", title, "--menu", prompt]
        for option in options:
            text = option.label
            if option.description:
                text += f" | {option.description}"
            command.extend([option.value, text])
        result = subprocess.run(command, text=True, capture_output=True, check=False)
        if result.returncode != 0:
            raise Cancelled
        value = result.stdout.strip()
        if value not in option_values(options):
            raise Cancelled
        return value

    def choose_many(self, title: str, prompt: str, options: Sequence[Option]) -> list[str]:
        command = ["kdialog", "--title", title, "--checklist", prompt]
        for option in options:
            command.extend([option.value, option.label, "off"])
        command.append("--separate-output")
        result = subprocess.run(command, text=True, capture_output=True, check=False)
        if result.returncode != 0:
            raise Cancelled
        selected = {value.strip() for value in result.stdout.splitlines() if value.strip()}
        if not selected.issubset(option_values(options)):
            raise Cancelled
        return [option.value for option in options if option.value in selected]


class YadUI(SelectorUI):
    def __init__(self, language: str) -> None:
        self.language = language

    def choose(self, title: str, prompt: str, options: Sequence[Option]) -> str:
        command = [
            "yad", "--list", "--title", title, "--text", prompt, "--column=ID:HD",
            f"--column={message(self.language, 'option')}",
            f"--column={message(self.language, 'detail')}", "--print-column=1",
            "--separator=", "--width=720", "--height=420",
        ]
        for option in options:
            command.extend([option.value, option.label, option.description])
        result = subprocess.run(command, text=True, capture_output=True, check=False)
        if result.returncode != 0:
            raise Cancelled
        value = result.stdout.strip()
        if value not in option_values(options):
            raise Cancelled
        return value

    def choose_many(self, title: str, prompt: str, options: Sequence[Option]) -> list[str]:
        command = [
            "yad", "--list", "--multiple", "--title", title, "--text", prompt,
            f"--column={message(self.language, 'selected')}:CHK", "--column=ID:HD",
            f"--column={message(self.language, 'option')}",
            f"--column={message(self.language, 'detail')}", "--print-column=2",
            "--separator=,", "--width=720", "--height=420",
        ]
        for option in options:
            command.extend(["FALSE", option.value, option.label, option.description])
        result = subprocess.run(command, text=True, capture_output=True, check=False)
        if result.returncode != 0:
            raise Cancelled
        selected = {value.strip() for value in result.stdout.split(",") if value.strip()}
        if not selected.issubset(option_values(options)):
            raise Cancelled
        return [option.value for option in options if option.value in selected]


def select_ui(force_text: bool, language: str) -> SelectorUI:
    has_display = bool(os.environ.get("DISPLAY") or os.environ.get("WAYLAND_DISPLAY"))
    if force_text or not has_display:
        return TextUI(language)
    if shutil.which("kdialog"):
        return KDialogUI(language)
    if shutil.which("yad"):
        return YadUI(language)
    return TextUI(language)


def command_name(provider: str) -> str:
    variable = f"AI_{provider.upper()}_EXECUTABLE"
    default = "agy" if provider == "antigravity" else provider
    return os.environ.get(variable, default)


