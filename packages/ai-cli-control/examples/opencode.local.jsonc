{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "local-router": {
      "name": "Local llama.cpp router",
      "options": {"baseURL": "http://127.0.0.1:18100/v1"}
    }
  },
  "agent": {
    "local-interactive": {
      "description": "Interactive local model with explicit permissions",
      "permission": {"read": "allow", "edit": "ask", "bash": "ask", "secret": "deny", "git push": "deny", "git merge": "deny", "publish": "deny"}
    },
    "local-worker": {
      "description": "Bounded worker. The orchestrator reviews its diff.",
      "permission": {"read": "allow", "edit": "allow", "bash": "ask", "secret": "deny", "git push": "deny", "git merge": "deny", "publish": "deny"}
    }
  }
}
