def _companion_used_percent_number(value: Any) -> float | None:
    """Finite usedPercent in [0, 100], or None when unusable (including float overflow)."""
    number = _codex_finite_number(value)
    if number is None or not _percent_in_range(number):
        return None
    return number


def _companion_usage_window_percents_ok(usage: dict[str, Any]) -> bool:
    """False when any primary/secondary/tertiary usedPercent is present and outside [0, 100]."""
    for key in ("primary", "secondary", "tertiary"):
        window = usage.get(key)
        if not isinstance(window, dict) or "usedPercent" not in window:
            continue
        if _companion_used_percent_number(window.get("usedPercent")) is None:
            return False
    return True


def _companion_entry_is_usable_usage(entry: dict[str, Any]) -> bool:
    """Usable companion usage: non-empty usage dict, no error key, valid usedPercent band."""
    if "error" in entry:
        return False
    usage = entry.get("usage")
    if not isinstance(usage, dict) or len(usage) == 0:
        return False
    return _companion_usage_window_percents_ok(usage)


def _companion_usable_entry_for_provider(entries: list[Any], provider: str) -> dict[str, Any] | None:
    """Return the first usable usage entry whose provider matches (case-insensitive)."""
    wanted = provider.lower()
    for entry in entries:
        if not isinstance(entry, dict):
            continue
        entry_provider = entry.get("provider")
        if not isinstance(entry_provider, str) or entry_provider.lower() != wanted:
            continue
        if _companion_entry_is_usable_usage(entry):
            return entry
    return None


def _sanitize_companion_usage_window(window: Any) -> dict[str, Any] | None:
    """Rebuild one usage window with only native keys. None rejects an invalid usedPercent."""
    if window is None:
        return None
    if not isinstance(window, dict):
        return None
    cleaned: dict[str, Any] = {}
    if "usedPercent" in window:
        percent = _companion_used_percent_number(window.get("usedPercent"))
        if percent is None:
            return None
        cleaned["usedPercent"] = percent
    if "windowMinutes" in window:
        minutes = _codex_finite_number(window.get("windowMinutes"))
        if minutes is not None and minutes >= 0:
            cleaned["windowMinutes"] = int(minutes)
    if "resetsAt" in window:
        resets_at = window.get("resetsAt")
        if isinstance(resets_at, str) and resets_at:
            cleaned["resetsAt"] = resets_at
    # Drop any other nested keys (token, raw, secrets).
    return cleaned


def _sanitize_companion_identity(identity: Any) -> dict[str, Any] | None:
    if not isinstance(identity, dict):
        return None
    cleaned: dict[str, Any] = {}
    for key in _COMPANION_IDENTITY_KEYS:
        value = identity.get(key)
        if isinstance(value, str) and value:
            cleaned[key] = value
    return cleaned or None


def _sanitize_companion_extra_rate_windows(items: Any) -> list[dict[str, Any]]:
    if not isinstance(items, list):
        return []
    extras: list[dict[str, Any]] = []
    for item in items:
        if not isinstance(item, dict):
            continue
        window = _sanitize_companion_usage_window(item.get("window"))
        if window is None:
            continue
        extra: dict[str, Any] = {"window": window}
        window_id = item.get("id")
        if isinstance(window_id, str) and window_id:
            extra["id"] = window_id
        title = item.get("title")
        if isinstance(title, str) and title:
            extra["title"] = title
        extras.append(extra)
    return extras


def _sanitize_companion_usage(usage: Any) -> dict[str, Any] | None:
    """Deep-rebuild usage to the native envelope schema (strict allowlist)."""
    if not isinstance(usage, dict) or len(usage) == 0:
        return None
    cleaned: dict[str, Any] = {}
    for key in ("primary", "secondary", "tertiary"):
        if key not in usage:
            continue
        raw_window = usage.get(key)
        if raw_window is None:
            cleaned[key] = None
            continue
        window = _sanitize_companion_usage_window(raw_window)
        if window is None and isinstance(raw_window, dict) and "usedPercent" in raw_window:
            # Invalid usedPercent: reject the whole usage blob.
            return None
        cleaned[key] = window
    if "identity" in usage:
        identity = _sanitize_companion_identity(usage.get("identity"))
        if identity is not None:
            cleaned["identity"] = identity
    if "updatedAt" in usage:
        updated_at = usage.get("updatedAt")
        if isinstance(updated_at, str) and updated_at:
            cleaned["updatedAt"] = updated_at
    if "extraRateWindows" in usage:
        extras = _sanitize_companion_extra_rate_windows(usage.get("extraRateWindows"))
        if extras:
            cleaned["extraRateWindows"] = extras
    # Any other top-level usage key (token, raw, cost blobs, …) is dropped by omission.
    return cleaned if cleaned else None


def _sanitize_companion_source(value: Any) -> str:
    if isinstance(value, str):
        normalized = value.strip().lower()
        if normalized in _COMPANION_KNOWN_SOURCES:
            return normalized
    return "auto"


def _sanitize_companion_usage_entry(entry: dict[str, Any], provider: str) -> dict[str, Any] | None:
    """Rebuild a companion usage entry with only expected fields (deep allowlist).

    Never copies arbitrary nested usage keys, unknown sources, or upstream engine values.
    Fallback path always marks engine as kodexbar (this suite's companion route).
    Returns None when deep rebuild leaves no usable native usage schema.
    """
    usage = _sanitize_companion_usage(entry.get("usage"))
    if usage is None:
        return None
    return {
        "provider": provider,
        "source": _sanitize_companion_source(entry.get("source")),
        "usage": usage,
        "engine": "kodexbar",
    }


def _antigravity_window_identity(item: dict[str, Any]) -> tuple[str | None, str | None]:
    """Classify an agy quota by stable id first, then its public title and duration."""
    window_id = str(item.get("id") or "").lower()
    title = str(item.get("title") or "").lower()
    window = item.get("window") if isinstance(item.get("window"), dict) else {}
    minutes = _codex_finite_number(window.get("windowMinutes"))
    text = f"{window_id} {title}"
    group = "gemini" if "gemini" in text else "claude-gpt" if (
        "3p" in text or "claude" in text or "gpt" in text
    ) else None
    kind = "weekly" if "weekly" in text or minutes == 10080 else "5h" if (
        "5h" in text or "5-hour" in text or minutes == 300
    ) else None
    return group, kind


def normalize_antigravity_rate_windows(usage: Any) -> list[dict[str, Any]]:
    """Return agy's model-group quota windows in its documented display order.

    Do not derive Session or Weekly from upstream primary/secondary. Those are
    implementation slots, and both can be five-hour limits. Unknown upstream
    extras remain visible under their own title after the classified windows.
    """
    if not isinstance(usage, dict):
        return []
    raw_items = usage.get("extraRateWindows")
    if not isinstance(raw_items, list):
        return []
    classified: dict[tuple[str, str], dict[str, Any]] = {}
    unknown: list[dict[str, Any]] = []
    for raw in raw_items:
        if not isinstance(raw, dict) or not isinstance(raw.get("window"), dict):
            continue
        group, kind = _antigravity_window_identity(raw)
        title = raw.get("title") if isinstance(raw.get("title"), str) and raw.get("title") else "Upstream quota"
        item = {
            "id": raw.get("id") if isinstance(raw.get("id"), str) else "",
            "title": title,
            "window": raw["window"],
        }
        if group and kind:
            item["key"] = f"{group}-{kind}"
            item["group"] = group
            item["windowType"] = kind
            classified[(group, kind)] = item
        else:
            item["key"] = re.sub(r"[^a-z0-9]+", "-", title.lower()).strip("-") or "upstream"
            item["windowType"] = "unknown"
            unknown.append(item)
    ordered = [
        classified[key]
        for key in (("gemini", "weekly"), ("gemini", "5h"), ("claude-gpt", "weekly"), ("claude-gpt", "5h"))
        if key in classified
    ]
    return ordered + unknown


def normalize_antigravity_entry(entry: Any) -> Any:
    """Add the frontend contract for agy without altering other providers."""
    if not isinstance(entry, dict) or str(entry.get("provider") or "").lower() != "antigravity":
        return entry
    usage = entry.get("usage")
    windows = normalize_antigravity_rate_windows(usage)
    if not isinstance(usage, dict) or not windows:
        return entry
    return {**entry, "usage": {**usage, "antigravityRateWindows": windows}}


def _dual_failure_message(provider: str, native_failure: FetchFallback, upstream_detail: str) -> str:
    """User-visible text when native and companion both failed (never leak upstream text)."""
    normalized = provider.lower()
    if normalized == "codex":
        return CODEX_BOTH_FAILED
    if normalized == "grok":
        return GROK_BOTH_FAILED
    return f"{native_failure}. Fallback failed: {upstream_detail}"


def fallback_entry(
    provider: str,
    source: str | None,
    native_failure: FetchFallback | None = None,
) -> list[Any]:
    try:
        entries = upstream_entries(provider, source)
    except FetchFallback as upstream_failure:
        failure = native_failure or upstream_failure
        if native_failure is None:
            # Normal passthrough delegation (e.g. antigravity): keep upstream text.
            message = str(upstream_failure)
        else:
            # Fallback after native failure: never surface companion/upstream raw text.
            message = _dual_failure_message(provider, native_failure, str(upstream_failure))
        return [provider_error(provider, source or "auto", message, failure.category, failure.retryable)]

    # Fallback after native failure: only the requested provider's usable usage entry.
    # Never return a mixed companion list (other providers, error siblings, secrets).
    if native_failure is not None:
        usable = _companion_usable_entry_for_provider(entries, provider)
        cleaned = _sanitize_companion_usage_entry(usable, provider) if usable is not None else None
        if cleaned is None:
            message = _dual_failure_message(
                provider, native_failure, "companion returned no usable usage for provider"
            )
            return [
                provider_error(
                    provider,
                    source or "auto",
                    message,
                    native_failure.category,
                    native_failure.retryable,
                )
            ]
        return [cleaned]

    # Antigravity keeps upstream acquisition, but gets one stable quota contract.
    return [normalize_antigravity_entry(entry) for entry in entries]


def _native_provider_result(
    provider: str,
    source: str | None,
    home: Path | None,
    fetch_fn: Callable[[Path | None], dict[str, Any]],
    default_source: str,
) -> list[Any]:
    """Run a native fetch.

    Fallback to installed upstream codexbar is decided by error CATEGORY:
    - authentication: never fall back (re-login message only)
    - network / timeout / invalid_response (schema drift, parse failure): fall back if present
    - permanent and other non-parse failures: no fall back
    """
    try:
        entry = fetch_fn(home)
    except FetchFallback as error:
        message = human_native_error_message(provider, error.category, str(error))
        if error.category == "authentication":
            return [
                provider_error(
                    provider,
                    source or default_source,
                    message,
                    "authentication",
                    False,
                )
            ]
        if error.category in NATIVE_UPSTREAM_FALLBACK_CATEGORIES and upstream_path() is not None:
            # Preserve category/retryable; surface human text if companion also fails.
            humanized = FetchFallback(message, error.category, error.retryable)
            return fallback_entry(provider, source, humanized)
        return [
            provider_error(
                provider,
                source or default_source,
                message,
                error.category,
                error.retryable,
            )
        ]
    # Auth/permanent errors returned as structured entries must not be re-routed to upstream.
    if isinstance(entry, dict) and "error" in entry:
        category = (entry.get("error") or {}).get("category")
        err_obj = entry.get("error") if isinstance(entry.get("error"), dict) else {}
        raw_message = str(err_obj.get("message") or "")
        if category in (None, ""):
            return [entry]
        # Humanize structured native errors (auth returned as entry, permanent plan issues).
        if provider.lower() in ("codex", "grok"):
            entry = {
                **entry,
                "error": {
                    **err_obj,
                    "message": human_native_error_message(provider, str(category), raw_message),
                },
            }
        if category == "authentication":
            return [entry]
        # Other structured native errors (e.g. permanent plan denial) stay as-is, no upstream.
        return [entry]
    return [entry]


def fetch_provider(provider: str, source: str | None, home: Path | None = None) -> list[Any]:
    normalized = provider.lower()
    if normalized == "claude" and source in (None, "auto", "oauth"):
        try:
            return [fetch_claude(home)]
        except FetchFallback as error:
            return fallback_entry(normalized, source, error)
    if normalized == "codex" and source in (None, "auto", "oauth"):
        return _native_provider_result(normalized, source, home, fetch_codex, "oauth")
    if normalized == "grok" and source in (None, "auto", "web", "grok-web"):
        return _native_provider_result(normalized, source, home, fetch_grok, "grok-web")
    return fallback_entry(normalized, source)


def parse_usage(arguments: list[str]) -> tuple[str, str | None, bool] | None:
    provider = None
    source = None
    pretty = False
    index = 0
    while index < len(arguments):
        argument = arguments[index]
        if argument in ("--json", "--json-only"):
            index += 1
        elif argument == "--pretty":
            pretty = True
            index += 1
        elif argument == "--format" and index + 1 < len(arguments) and arguments[index + 1] == "json":
            index += 2
        elif argument == "--provider" and index + 1 < len(arguments):
            provider = arguments[index + 1].lower()
            index += 2
        elif argument == "--source" and index + 1 < len(arguments):
            source = arguments[index + 1].lower()
            index += 2
        else:
            return None
    return provider or "enabled", source, pretty


def delegate_whole_call(arguments: list[str], executable: str | None = None) -> int:
    resolved = executable if executable is not None else upstream_path()
    if resolved is None:
        print("kodexbar-quotas: upstream codexbar is not installed", file=sys.stderr)
        return 127
    return subprocess.call([resolved, *arguments])


def print_json(value: Any, pretty: bool) -> None:
    print(json.dumps(value, indent=2 if pretty else None, ensure_ascii=False))


def main(arguments: list[str]) -> int:
    if not arguments:
        return delegate_whole_call(arguments)
    if arguments[0] == "cost":
        if arguments[1:] == ["--format", "json", "--json-only"]:
            executable = upstream_path()
            if executable is None:
                print_json([], False)
                return 0
        return delegate_whole_call(arguments)
    if arguments[0] != "usage":
        return delegate_whole_call(arguments)
    parsed = parse_usage(arguments[1:])
    if parsed is None:
        return delegate_whole_call(arguments)
    requested, source, pretty = parsed
    # When config is missing, auto-detect installed CLIs and write ~/.config/codexbar/config.json
    # once (never overwrites an existing file). After a successful write, the normal config path runs.
    ensure_auto_config()

    def emit_provider_usage(provider_ids: list[str]) -> int:
        usage_entries: list[Any] = []
        for provider in provider_ids:
            # Codex and Grok always go through fetch_provider (native first). Only true
            # passthrough providers (antigravity and unknowns) use upstream fallback_entry.
            usage_entries.extend(fetch_provider(provider, source))
        print_json(usage_entries, pretty)
        return 0

    def absent_or_unreadable_config_usage(*, malformed: bool) -> int:
        """Config absent/malformed path without whole-call delegation of codex/grok.

        Explicit --provider codex|grok always uses the native-first fetch_provider path.
        --provider all with upstream present walks AUTO_CONFIG_PROVIDER_IDS per provider
        so codex/grok never skip credentials via full upstream argv delegation.
        """
        if requested not in ("enabled", "all"):
            return emit_provider_usage([requested])

        if not malformed and has_claude_credentials():
            if requested == "all":
                # "all" still includes native codex/grok even without a written config.
                return emit_provider_usage(list(AUTO_CONFIG_PROVIDER_IDS))
            return emit_provider_usage(["claude"])

        if requested == "all":
            upstream = upstream_path()
            if upstream is not None or malformed:
                # Per-provider native-first for the suite set. Never delegate the whole argv.
                return emit_provider_usage(list(AUTO_CONFIG_PROVIDER_IDS))
            print_json([first_run_claude_guidance_entry()], pretty)
            return 0

        # requested == "enabled" without a usable enabled list
        print_json([first_run_claude_guidance_entry()], pretty)
        return 0

    try:
        enabled = enabled_providers()
    except FileNotFoundError:
        return absent_or_unreadable_config_usage(malformed=False)
    except (OSError, ValueError, json.JSONDecodeError) as error:
        # Config path exists but is unreadable/malformed: never repair.
        if isinstance(error, OSError) and not codexbar_config_path().is_file():
            return absent_or_unreadable_config_usage(malformed=False)
        return absent_or_unreadable_config_usage(malformed=True)
    providers = enabled if requested in ("enabled", "all") else [requested]
    return emit_provider_usage(providers)


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
